
<% facility_panel_open = selected_panel.in?(%w[inn item_shop blacksmith equipment items skills]) && @player.location&.safe_area? %>
<% if facility_panel_open %>
  <div class="card bg-secondary text-light mb-3">
    <% if selected_panel == "items" %>

      <div class="card-header">所持品一覧</div>
      <div class="card-body">

        <% if params[:item_category] == "weapons" %>

          <% @player.weapons.each do |weapon| %>
            <div class="border rounded mb-2">
              <button class="btn btn-dark w-100 text-start"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#weapon-item-<%= weapon.id %>">

                <%= weapon.display_name %>
                <% if weapon.equipped? %>（装備中）<% end %>

              </button>

              <div class="collapse p-2"
                  id="weapon-item-<%= weapon.id %>">

                <p>攻撃力: <%= weapon.attack_power %></p>
                <p>耐久力: <%= weapon.durability %>/<%= weapon.max_durability %></p>

                <% unless weapon.equipped? %>
                  <%= button_to "装備する",
                      equip_weapon_path(weapon_id: weapon.id),
                      method: :post,
                      class: "btn btn-outline-warning w-100" %>
                <% end %>
              </div>
            </div>
          <% end %>

        <% elsif params[:item_category] == "armors" %>

          <% @player.armors.each do |armor| %>

            <div class="border rounded mb-2">
              <button class="btn btn-dark w-100 text-start"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#armor-item-<%= armor.id %>">

                <%= armor.name %>
                <% if armor.equipped? %>（装備中）<% end %>

              </button>

              <div class="collapse p-2"
                  id="armor-item-<%= armor.id %>">

                <p>防御力: <%= armor.defense %></p>
                <p>重量: <%= armor.weight %></p>

              </div>
            </div>

          <% end %>

        <% elsif params[:item_category].in?(%w[healing gathered drop]) %>

          <% items = @player.items.where(category: params[:item_category])
                                  .where("quantity > 0")
                                  .order(:name) %>

          <% items.each do |item| %>

            <div class="border rounded mb-2">

              <button class="btn btn-dark w-100 text-start"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#item-right-<%= item.id %>">

                <%= item.name %> × <%= item.quantity %>

              </button>

              <div class="collapse p-2"
                  id="item-right-<%= item.id %>">

                <% if item.category == "healing" %>
                  <%= button_to "使う",
                      use_item_path(item_name: item.name),
                      method: :post,
                      class: "btn btn-outline-success w-100 mb-2" %>
                <% end %>

                <% if item.discardable_by_player? %>
                  <%= button_to "全部捨てる",
                      discard_item_path(
                        item_id: item.id,
                        quantity: item.quantity
                      ),
                      method: :post,
                      class: "btn btn-outline-danger w-100" %>
                <% end %>

              </div>

            </div>

          <% end %>

        <% end %>

      </div>
    
    <% elsif selected_panel == "skills" %>
      <div class="card-header">スキル詳細</div>
      <div class="card-body">
        <% skill = @player.skills.find_by(name: params[:skill_set]) %>
        <% if skill %>
          <p>
            熟練度:
            <%= skill.proficiency.to_i %> / 1000
          </p>
          <div class="progress mb-3">
            <div class="progress-bar"
                style="width:<%= skill.proficiency.to_i / 10 %>%">
            </div>
          </div>
          <% learned_sword_skills = SkillCatalog.sword_skills(skill.name).select { |s| skill.proficiency.to_i >= s.required_proficiency } %>
          <% selected_sword_skill = learned_sword_skills.find { |s| s.key == params[:sword_skill] } %>
          <% if learned_sword_skills.any? %>
            <h6>習得済みソードスキル</h6>
            <div class="d-grid gap-2 mb-3">
              <% learned_sword_skills.each do |s| %>
                <div>
                  <%= link_to s.name,
                      game_path(panel: "skills", skill_set: skill.name, sword_skill: s.key),
                      class: "btn #{selected_sword_skill&.key == s.key ? 'btn-info' : 'btn-outline-light'} w-100" %>
                  <% if selected_sword_skill&.key == s.key %>
                    <div class="border rounded p-2 mt-2">
                      <p class="mb-1">威力倍率: <%= s.damage_multiplier %>%</p>
                      <p class="mb-1">ヒット数: <%= s.hits %></p>
                      <p class="mb-1">種別: <%= s.target_label %></p>
                      <p class="mb-0"><%= s.description %></p>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% elsif selected_panel == "equipment" %>
      <div class="card-header">所持装備</div>
      <div class="card-body">
        <h6>所持武器</h6>

        <% @player.weapons.each do |weapon| %>
          <div class="border rounded mb-2">
            <button class="btn btn-dark w-100 text-start"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#weapon-<%= weapon.id %>">
              <%= weapon.display_name %>
              <% if weapon.equipped? %>（装備中）<% end %>
              <% if weapon.favorite? %> ★<% end %>
            </button>

            <div class="collapse p-2" id="weapon-<%= weapon.id %>">
              <p class="mb-1">攻撃力: <%= weapon.attack_power %></p>
              <p class="mb-1">耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
              <p class="mb-1">クリティカル率: <%= weapon.critical_rate %>%</p>

              <% unless weapon.equipped? %>
                <%= button_to "装備する", equip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-warning w-100 mt-2" %>
              <% else %>
                <%= button_to "取り外す", unequip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
              <% end %>
              <%= button_to weapon.favorite? ? "★ お気に入り解除" : "☆ お気に入り登録",
                  toggle_weapon_favorite_path(weapon_id: weapon.id),
                  method: :post,
                  class: "btn btn-outline-light w-100 mt-2" %>
            </div>
          </div>
        <% end %>

        <h6 class="mt-3">所持防具</h6>

        <% @player.armors.each do |armor| %>
          <div class="border rounded mb-2">
            <button class="btn btn-dark w-100 text-start"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#armor-<%= armor.id %>">
              <%= armor.name %>
              <% if armor.equipped? %>（装備中）<% end %>
              <% if armor.favorite? %> ★<% end %>
            </button>

            <div class="collapse p-2" id="armor-<%= armor.id %>">
              <p class="mb-1">部位: <%= armor.slot_name %></p>
              <p class="mb-1">防御: <%= armor.defense %></p>
              <p class="mb-1">重量: <%= armor.weight %></p>

              <% if armor.equipped? %>
                <%= button_to "取り外す", unequip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
              <% else %>
                <%= button_to "装備する", equip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-info w-100 mt-2" %>
              <% end %>
              <%= button_to armor.favorite? ? "★ お気に入り解除" : "☆ お気に入り登録",
                  toggle_armor_favorite_path(armor_id: armor.id),
                  method: :post,
                  class: "btn btn-outline-light w-100 mt-2" %>
            </div>
          </div>
        <% end %>
      </div>

    <% elsif selected_panel == "inn" %>
      <% inn_menu = params[:inn_menu].presence || "rest" %>
      <% inn_cost = @player.location&.name == "ホルンカの村" ? 50 : 0 %>
      <% temporary_only = @player.location&.name == "ホルンカの村" %>
      <% current_base = @player.player_bases.find_by(location: @player.location, base_type: temporary_only ? "temporary" : "home", active: true) %>
      <% current_home_base = temporary_only ? nil : current_base %>
      <% base_label = temporary_only ? "仮拠点" : "本拠点" %>
      <% inn_cost = current_base ? 0 : inn_cost %>

      <div class="card-header">宿屋</div>
      <div class="card-body">
        <% if inn_menu == "rest" %>
          <h6>休憩</h6>
          <p>宿屋で休憩してHPを回復します。</p>
          <%= button_to "休憩する（#{inn_cost}コル）", inn_path, method: :post, class: "btn btn-outline-success w-100" %>

        <% elsif inn_menu == "base" %>
          <h6><%= base_label %></h6>
          <% if temporary_only %>
            <% if current_base&.temporary? %>
              <p>現在の仮拠点です。</p>
            <% else %>
              <p>この宿屋は仮拠点にできます。</p>
            <% end %>
          <% elsif @player.home_base %>
            <p>現在の本拠点: <%= @player.home_base.location.name %></p>
          <% else %>
            <p>本拠点は未設定です。</p>
          <% end %>

          <% if current_base.blank? %>
            <% if params[:confirm_home_base] == "1" %>
              <div class="border border-info rounded p-2">
                <p class="mb-2">ここを<%= base_label %>にしますか？</p>
                <div class="d-flex gap-2">
                  <%= button_to "はい", set_home_base_path(confirm: "1"), method: :post, form: { class: "flex-fill" }, class: "btn btn-info w-100" %>
                  <%= link_to "いいえ", game_path(panel: "inn", inn_menu: "base"), class: "btn btn-outline-light flex-fill" %>
                </div>
              </div>
            <% else %>
              <%= link_to "この宿屋を#{base_label}にする", game_path(panel: "inn", inn_menu: "base", confirm_home_base: "1"), class: "btn btn-outline-info w-100" %>
            <% end %>
          <% else %>
            <div class="text-info small text-center">現在の<%= base_label %>です</div>
            <% if current_base&.temporary? %>
              <%= button_to "仮拠点を解除する", remove_temporary_base_path, method: :post, class: "btn btn-outline-danger w-100 mt-2" %>
            <% end %>
          <% end %>

        <% elsif inn_menu == "col" %>
          <h6>所持金管理</h6>
          <% if current_home_base %>
            <p>預け金: <%= @player.base_col.to_i %>コル</p>
            <%= form_with url: deposit_base_col_path, method: :post, class: "d-grid gap-2 mb-3" do %>
              <%= number_field_tag :amount, 100, min: 1, max: @player.col.to_i, class: "form-control form-control-sm" %>
              <%= submit_tag "コルを預ける", class: "btn btn-outline-info w-100" %>
            <% end %>
            <%= form_with url: withdraw_base_col_path, method: :post, class: "d-grid gap-2" do %>
              <%= number_field_tag :amount, 100, min: 1, max: @player.base_col.to_i, class: "form-control form-control-sm" %>
              <%= submit_tag "コルを引き出す", class: "btn btn-outline-light w-100" %>
            <% end %>
          <% else %>
            <p class="text-secondary small mb-0">この宿屋は本拠点ではないため、所持金管理は使えません。</p>
          <% end %>

        <% elsif inn_menu == "storage" %>
          <h6>アイテム収納</h6>
          <% if current_base %>
            <p class="small text-info mb-2">収納種類: <%= current_base.storage_type_count %> / <%= current_base.storage_limit %>（あと <%= current_base.remaining_storage_slots %> 種類）</p>
          <% end %>
          <% if current_base %>
            <% storage_tab = params[:storage_tab].presence || "store" %>
            <% item_category = params[:item_category].presence %>
            <% category_buttons = [[nil, "全部"], ["weapons", "武器"], ["armors", "防具"], ["healing", "回復"], ["gathered", "採取"], ["drop", "ドロップ"]] %>
            <ul class="nav nav-tabs mb-2">
              <li class="nav-item"><%= link_to "預ける", game_path(panel: "inn", inn_menu: "storage", storage_tab: "store", item_category: item_category), class: "nav-link #{storage_tab == 'store' ? 'active' : ''}" %></li>
              <li class="nav-item"><%= link_to "取り出す", game_path(panel: "inn", inn_menu: "storage", storage_tab: "withdraw", item_category: item_category), class: "nav-link #{storage_tab == 'withdraw' ? 'active' : ''}" %></li>
              <li class="nav-item"><%= link_to "輸送", game_path(panel: "inn", inn_menu: "storage", storage_tab: "transfer", item_category: item_category), class: "nav-link #{storage_tab == 'transfer' ? 'active' : ''}" %></li>
            </ul>
            <div class="d-flex gap-2 mb-3 flex-wrap">
              <% category_buttons.each do |category, label| %>
                <%= link_to label, game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab, item_category: category), class: "btn btn-sm #{item_category == category ? 'btn-info' : 'btn-outline-light'}" %>
              <% end %>
            </div>

            <% if storage_tab == "store" %>
              <%= button_to "表示中の種類をすべて預ける", bulk_store_items_path(item_category: item_category), method: :post, class: "btn btn-outline-info w-100 mb-3" %>
              <% carried_items = @player.items.where("quantity > 0").order(:category, :name) %>
              <% carried_items = carried_items.where(category: item_category) if item_category.present? && !%w[weapons armors].include?(item_category) %>
              <% carried_weapons = item_category.blank? || item_category == "weapons" ? @player.weapons.where(equipped: false, favorite: false).order(:name) : [] %>
              <% carried_armors = item_category.blank? || item_category == "armors" ? @player.armors.where(equipped: false, favorite: false).order(:slot, :name) : [] %>

              <% if carried_weapons.any? %>
                <h6 class="mt-2">武器</h6>
                <div class="d-grid gap-2 mb-2">
                  <% carried_weapons.each do |weapon| %>
                    <div class="border rounded p-2">
                      <p class="mb-1"><%= weapon.display_name %> / 耐久 <%= weapon.durability %> / <%= weapon.max_durability %></p>
                      <%= button_to "預ける", store_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-light btn-sm w-100" %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <% if carried_armors.any? %>
                <h6 class="mt-2">防具</h6>
                <div class="d-grid gap-2 mb-2">
                  <% carried_armors.each do |armor| %>
                    <div class="border rounded p-2">
                      <p class="mb-1"><%= armor.name %> / <%= armor.slot_name %></p>
                      <%= button_to "預ける", store_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-light btn-sm w-100" %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <% if item_category == "drop" %>
                <% drop_groups = carried_items.group_by { |item| item.name.to_s.split("の").first } %>
                <% if drop_groups.any? %>
                  <h6 class="mt-2">ドロップアイテム</h6>
                  <div class="d-grid gap-2">
                    <% drop_groups.each do |group_name, items| %>
                      <div class="border rounded">
                        <button class="btn btn-dark w-100 text-start" type="button" data-bs-toggle="collapse" data-bs-target="#store-drop-<%= group_name.hash.abs %>"><%= group_name %>関連（<%= items.size %>種類）</button>
                        <div class="collapse p-2" id="store-drop-<%= group_name.hash.abs %>">
                          <% items.each do |item| %>
                            <%= form_with url: store_item_path(item_id: item.id), method: :post, class: "d-flex gap-2 mb-2" do %>
                              <span class="flex-fill"><%= item.name %> × <%= item.quantity %></span>
                              <%= number_field_tag :quantity, item.quantity, min: 1, max: item.quantity, class: "form-control form-control-sm", style: "max-width: 90px;" %>
                              <%= submit_tag "預ける", class: "btn btn-outline-light btn-sm" %>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% elsif !%w[weapons armors].include?(item_category.to_s) %>
                <% if carried_items.any? %>
                  <h6 class="mt-2">アイテム</h6>
                  <div class="d-grid gap-2">
                    <% carried_items.each do |item| %>
                      <div class="border rounded p-2">
                        <%= form_with url: store_item_path(item_id: item.id), method: :post, class: "d-flex gap-2" do %>
                          <span class="flex-fill"><%= item.name %> × <%= item.quantity %></span>
                          <%= number_field_tag :quantity, item.quantity, min: 1, max: item.quantity, class: "form-control form-control-sm", style: "max-width: 90px;" %>
                          <%= submit_tag "預ける", class: "btn btn-outline-light btn-sm" %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% end %>

              <% if carried_items.empty? && carried_weapons.empty? && carried_armors.empty? %>
                <p class="text-secondary small mb-0">預けられる所持品はありません。</p>
              <% end %>

            <% elsif storage_tab == "withdraw" %>
              <%= button_to "表示中の種類をすべて取り出す", bulk_withdraw_items_path(item_category: item_category), method: :post, class: "btn btn-outline-info w-100 mb-3" %>
              <% storage_items = current_base.storage_items.where("quantity > 0").order(:category, :name) %>
              <% storage_items = storage_items.where(category: item_category) if item_category.present? && !%w[weapons armors].include?(item_category) %>
              <% stored_weapons = item_category.blank? || item_category == "weapons" ? current_base.stored_weapons.order(:name) : [] %>
              <% stored_armors = item_category.blank? || item_category == "armors" ? current_base.stored_armors.order(:slot, :name) : [] %>

              <% if stored_weapons.any? %>
                <h6 class="mt-2">武器</h6>
                <div class="d-grid gap-2 mb-2">
                  <% stored_weapons.each do |weapon| %>
                    <div class="border rounded p-2">
                      <p class="mb-1"><%= weapon.display_name %> / 耐久 <%= weapon.durability %> / <%= weapon.max_durability %></p>
                      <%= button_to "取り出す", withdraw_weapon_path(weapon_id: weapon.id, item_category: item_category), method: :post, class: "btn btn-outline-light btn-sm w-100" %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <% if stored_armors.any? %>
                <h6 class="mt-2">防具</h6>
                <div class="d-grid gap-2 mb-2">
                  <% stored_armors.each do |armor| %>
                    <div class="border rounded p-2">
                      <p class="mb-1"><%= armor.name %> / <%= armor.slot_name %></p>
                      <%= button_to "取り出す", withdraw_armor_path(armor_id: armor.id, item_category: item_category), method: :post, class: "btn btn-outline-light btn-sm w-100" %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <% if item_category == "drop" %>
                <% drop_groups = storage_items.group_by { |item| item.name.to_s.split("の").first } %>
                <% if drop_groups.any? %>
                  <h6 class="mt-2">ドロップアイテム</h6>
                  <div class="d-grid gap-2">
                    <% drop_groups.each do |group_name, items| %>
                      <div class="border rounded">
                        <button class="btn btn-dark w-100 text-start" type="button" data-bs-toggle="collapse" data-bs-target="#withdraw-drop-<%= group_name.hash.abs %>"><%= group_name %>関連（<%= items.size %>種類）</button>
                        <div class="collapse p-2" id="withdraw-drop-<%= group_name.hash.abs %>">
                          <% items.each do |storage_item| %>
                            <%= form_with url: withdraw_item_path(storage_item_id: storage_item.id), method: :post, class: "d-flex gap-2 mb-2" do %>
                              <span class="flex-fill"><%= storage_item.name %> × <%= storage_item.quantity %></span>
                              <%= number_field_tag :quantity, storage_item.quantity, min: 1, max: storage_item.quantity, class: "form-control form-control-sm", style: "max-width: 90px;" %>
                              <%= submit_tag "取り出す", class: "btn btn-outline-light btn-sm" %>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% elsif !%w[weapons armors].include?(item_category.to_s) %>
                <% if storage_items.any? %>
                  <h6 class="mt-2">アイテム</h6>
                  <div class="d-grid gap-2">
                    <% storage_items.each do |storage_item| %>
                      <div class="border rounded p-2">
                        <%= form_with url: withdraw_item_path(storage_item_id: storage_item.id), method: :post, class: "d-flex gap-2" do %>
                          <span class="flex-fill"><%= storage_item.name %> × <%= storage_item.quantity %></span>
                          <%= number_field_tag :quantity, storage_item.quantity, min: 1, max: storage_item.quantity, class: "form-control form-control-sm", style: "max-width: 90px;" %>
                          <%= submit_tag "取り出す", class: "btn btn-outline-light btn-sm" %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% end %>

              <% if storage_items.empty? && stored_weapons.empty? && stored_armors.empty? %>
                <p class="text-secondary small mb-0">収納中のものはありません。</p>
              <% end %>

            <% elsif storage_tab == "transfer" %>
              <% destination_bases = @player.player_bases.where(active: true).where.not(id: current_base.id).includes(:location).to_a %>
              <% storage_items = current_base.storage_items.where("quantity > 0").order(:category, :name) %>
              <% storage_items = StorageItem.none if %w[weapons armors].include?(item_category.to_s) %>
              <% storage_items = storage_items.where(category: item_category) if item_category.present? && !%w[weapons armors].include?(item_category) %>
              <% stored_weapons = item_category.blank? || item_category == "weapons" ? current_base.stored_weapons.order(:name) : [] %>
              <% stored_armors = item_category.blank? || item_category == "armors" ? current_base.stored_armors.order(:slot, :name) : [] %>
              <% if params[:confirm_transfer] == "1" %>
                <% destination_base = destination_bases.find { |base| base.id == params[:destination_base_id].to_i } %>
                <div class="border border-info rounded p-2 mb-3">
                  <p class="mb-1"><%= params[:transfer_labels] %></p>
                  <p class="mb-1"><%= destination_base&.location_name || "輸送先" %> に <%= params[:transfer_cost] %>コルで輸送します。</p>
                  <p class="small text-secondary mb-2">総重量: <%= params[:transfer_weight] %></p>
                  <div class="d-flex gap-2">
                    <%= form_with url: transfer_base_item_path, method: :post, class: "flex-fill" do %>
                      <%= hidden_field_tag :confirm, "1" %>
                      <%= hidden_field_tag :destination_base_id, params[:destination_base_id] %>
                      <% Array(params[:storage_item_ids]).each do |id| %>
                        <%= hidden_field_tag "storage_item_ids[]", id %>
                      <% end %>
                      <% Array(params[:weapon_ids]).each do |id| %>
                        <%= hidden_field_tag "weapon_ids[]", id %>
                      <% end %>
                      <% Array(params[:armor_ids]).each do |id| %>
                        <%= hidden_field_tag "armor_ids[]", id %>
                      <% end %>
                      <%= submit_tag "はい", class: "btn btn-info w-100" %>
                    <% end %>
                    <%= link_to "いいえ", game_path(panel: "inn", inn_menu: "storage", storage_tab: "transfer", item_category: item_category), class: "btn btn-outline-light flex-fill" %>
                  </div>
                </div>
              <% elsif destination_bases.any? && (storage_items.any? || stored_weapons.any? || stored_armors.any?) %>
                <p class="small text-warning mb-2">輸送にはコルが必要です。最低輸送費は道中危険度で変動し、重量10までは最低費用内、それ以上は重いほど加算されます。</p>
                <%= form_with url: transfer_base_item_path, method: :post, class: "d-grid gap-2" do %>
                  <%= select_tag :destination_base_id, options_from_collection_for_select(destination_bases, :id, :location_name, params[:destination_base_id]), class: "form-select form-select-sm" %>
                  <% storage_items.each do |storage_item| %>
                    <label class="border rounded p-2"><%= check_box_tag "storage_item_ids[]", storage_item.id, Array(params[:storage_item_ids]).map(&:to_s).include?(storage_item.id.to_s) %> <%= storage_item.name %> × <%= storage_item.quantity %></label>
                  <% end %>
                  <% stored_weapons.each do |weapon| %>
                    <label class="border rounded p-2"><%= check_box_tag "weapon_ids[]", weapon.id, Array(params[:weapon_ids]).map(&:to_s).include?(weapon.id.to_s) %> <%= weapon.display_name %>（武器 / 重さ <%= weapon.weight %>）</label>
                  <% end %>
                  <% stored_armors.each do |armor| %>
                    <label class="border rounded p-2"><%= check_box_tag "armor_ids[]", armor.id, Array(params[:armor_ids]).map(&:to_s).include?(armor.id.to_s) %> <%= armor.name %>（防具 / 重さ <%= armor.weight %>）</label>
                  <% end %>
                  <%= submit_tag "輸送内容を確認する", class: "btn btn-outline-info w-100" %>
                <% end %>
              <% elsif destination_bases.empty? %>
                <p class="text-secondary small mb-0">輸送先の拠点がありません。</p>
              <% else %>
                <p class="text-secondary small mb-0">輸送できるものがありません。</p>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-secondary small mb-0">この宿屋を拠点にすると、アイテム収納を使えます。</p>
          <% end %>
        <% end %>
      </div>    <% elsif selected_panel == "item_shop" %>
      <% shop_menu = params[:shop_menu].presence %>
      <div class="card-header">道具屋</div>
      <div class="card-body">
        <% if shop_menu == "buy" %>
          <% shop_items = ShopCatalog.item_shop_items(@player.location) %>
          <% selected_shop_item = shop_items.find { |shop_item| shop_item.item_name == params[:item_name] } %>
          <% if selected_shop_item %>
            <%= link_to "販売一覧に戻る", game_path(panel: "item_shop", shop_menu: "buy"), class: "btn btn-outline-light w-100 mb-3" %>
            <h6><%= selected_shop_item.item_name %></h6>
            <p class="mb-1">価格: <%= selected_shop_item.price %>コル</p>
            <p class="mb-1">種別: <%= selected_shop_item.category %></p>
            <p class="mb-1">重さ: <%= Item.new(name: selected_shop_item.item_name, category: selected_shop_item.category).weight %></p>
            <% if selected_shop_item.item_name == "ポーション" %>
              <p class="mb-2">効果: HPを100回復</p>
            <% else %>
              <p class="mb-2">効果: 使用効果なし</p>
            <% end %>
            <%= button_to "購入する", item_shop_path(item_name: selected_shop_item.item_name), method: :post, class: "btn btn-warning w-100" %>
          <% elsif shop_items.any? %>
            <div class="d-grid gap-2">
              <% shop_items.each do |shop_item| %>
                <%= link_to "#{shop_item.item_name} / #{shop_item.price}コル / #{shop_item.category}",
                    game_path(panel: "item_shop", shop_menu: "buy", item_name: shop_item.item_name),
                    class: "btn btn-outline-warning w-100" %>
              <% end %>
            </div>
          <% else %>
            <p class="mb-0">この町の道具屋には販売品がありません。</p>
          <% end %>
        <% elsif shop_menu == "produce" %>
          <% herb = @player.items.find_by(name: "薬草", category: "gathered") || @player.items.find_by(name: "薬草") %>
          <%= link_to "道具屋メニューに戻る", game_path(panel: "item_shop"), class: "btn btn-outline-light w-100 mb-3" %>
          <h6>ポーション</h6>
          <p class="mb-1">必要素材: 薬草 10個</p>
          <p class="mb-1">費用: 20コル</p>
          <p class="mb-2">所持薬草: <%= (herb&.quantity || 0).to_i %></p>
          <%= button_to "ポーションを生産する", produce_item_path, method: :post, class: "btn btn-outline-warning w-100" %>
        <% elsif shop_menu == "sell" %>
          <% sellable_items = @player.items.select { |item| item.quantity.to_i.positive? && (item.sellable_by_player? || item.unique_item?) } %>
          <% selected_sell_item = sellable_items.find { |item| item.id == params[:item_id].to_i } %>
          <% sell_category = params[:item_category].presence %>
          <% listed_sell_items = sell_category.present? ? sellable_items.select { |item| item.category == sell_category } : sellable_items %>
          <% if selected_sell_item %>
            <%= link_to "売却一覧に戻る", game_path(panel: "item_shop", shop_menu: "sell", item_category: sell_category), class: "btn btn-outline-light w-100 mb-3" %>
            <div class="border rounded p-2">
              <h6><%= selected_sell_item.name %></h6>
              <p class="mb-1">所持数: <%= selected_sell_item.quantity %></p>
              <p class="mb-1">種別: <%= selected_sell_item.category %></p>
              <p class="mb-2">売却価格: 1個 <%= selected_sell_item.sell_price %>コル</p>
              <% if selected_sell_item.unique_item? && params[:confirm_item_id].to_i != selected_sell_item.id %>
                <%= link_to "売却確認へ", game_path(panel: "item_shop", shop_menu: "sell", item_id: selected_sell_item.id, confirm_item_id: selected_sell_item.id, item_category: sell_category), class: "btn btn-outline-danger w-100" %>
              <% else %>
                <% if selected_sell_item.unique_item? %>
                  <p class="text-danger small mb-2">このアイテムは二度と手に入らないかもしれません。本当に売却しますか？</p>
                <% end %>
                <%= form_with url: sell_item_path, method: :post, class: "d-grid gap-2 mb-2" do %>
                  <%= hidden_field_tag :item_name, selected_sell_item.name %>
                  <%= hidden_field_tag :confirm_unique, "1" if selected_sell_item.unique_item? %>
                  <%= number_field_tag :quantity, 1, min: 1, max: selected_sell_item.quantity, class: "form-control form-control-sm" %>
                  <%= submit_tag "選択数を売却する", class: "btn btn-outline-warning w-100" %>
                <% end %>
                <%= button_to "すべて売却する",
                    sell_item_path(item_name: selected_sell_item.name, sell_all: "1", confirm_unique: selected_sell_item.unique_item? ? "1" : nil),
                    method: :post,
                    class: "btn btn-warning w-100" %>
              <% end %>
            </div>
          <% elsif sellable_items.any? %>
            <div class="d-flex gap-2 mb-3 flex-wrap">
              <%= link_to "全部", game_path(panel: "item_shop", shop_menu: "sell"), class: "btn btn-sm #{sell_category.blank? ? 'btn-warning' : 'btn-outline-light'}" %>
              <%= link_to "回復", game_path(panel: "item_shop", shop_menu: "sell", item_category: "healing"), class: "btn btn-sm #{sell_category == 'healing' ? 'btn-warning' : 'btn-outline-light'}" %>
              <%= link_to "採取", game_path(panel: "item_shop", shop_menu: "sell", item_category: "gathered"), class: "btn btn-sm #{sell_category == 'gathered' ? 'btn-warning' : 'btn-outline-light'}" %>
              <%= link_to "ドロップ", game_path(panel: "item_shop", shop_menu: "sell", item_category: "drop"), class: "btn btn-sm #{sell_category == 'drop' ? 'btn-warning' : 'btn-outline-light'}" %>
            </div>
            <% if listed_sell_items.any? %>
              <div class="d-grid gap-2">
                <% listed_sell_items.each do |item| %>
                  <%= link_to "#{item.name} × #{item.quantity} / 1個 #{item.sell_price}コル",
                      game_path(panel: "item_shop", shop_menu: "sell", item_id: item.id, item_category: sell_category),
                      class: "btn btn-outline-warning w-100" %>
                <% end %>
              </div>
            <% else %>
              <p class="mb-0">この種類で売却できるアイテムはありません。</p>
            <% end %>
          <% else %>
            <p class="mb-0">売却できるアイテムがありません。</p>
          <% end %>
        <% else %>
          <p class="mb-0">左のメニューから行動を選択してください。</p>
        <% end %>
      </div>
    <% elsif selected_panel == "blacksmith" %>
      <% blacksmith_menu = params[:blacksmith_menu].presence %>
      <div class="card-header">鍛冶屋</div>
      <div class="card-body">
      <% if blacksmith_menu == "buy" %>
        <% shop_weapons = ShopCatalog.blacksmith_weapons(@player.location) %>
        <% selected_shop_weapon = shop_weapons.find { |weapon| weapon.name == params[:weapon_name] } %>
        <% if selected_shop_weapon %>
          <%= link_to "販売一覧に戻る", game_path(panel: "blacksmith", blacksmith_menu: "buy"), class: "btn btn-outline-light w-100 mb-3" %>
          <h6><%= selected_shop_weapon.name %></h6>
          <p class="mb-1">価格: <%= selected_shop_weapon.price %>コル</p>
          <p class="mb-1">武器種: <%= selected_shop_weapon.weapon_type %></p>
          <p class="mb-1">攻撃力: <%= selected_shop_weapon.attack_power %></p>
          <p class="mb-1">攻撃属性: <%= selected_shop_weapon.attack_attributes %></p>
          <p class="mb-1">耐久力: <%= selected_shop_weapon.durability %> / <%= selected_shop_weapon.max_durability %></p>
          <p class="mb-1">重さ: <%= selected_shop_weapon.weight %></p>
          <p class="mb-1">参照ステータス: 筋力<%= selected_shop_weapon.strength_ratio %>% / 敏捷<%= selected_shop_weapon.agility_ratio %>%</p>
          <p class="mb-1">補正: HP +<%= selected_shop_weapon.hp_bonus %> / 筋力 +<%= selected_shop_weapon.strength_bonus %> / 敏捷 +<%= selected_shop_weapon.agility_bonus %></p>
          <% if selected_shop_weapon.description.present? %>
            <p class="mb-2"><%= selected_shop_weapon.description %></p>
          <% end %>
          <%= button_to "購入する", buy_bronze_sword_path(weapon_name: selected_shop_weapon.name), method: :post, class: "btn btn-warning w-100" %>
        <% elsif shop_weapons.any? %>
          <div class="d-grid gap-2">
            <% shop_weapons.each do |weapon| %>
              <%= link_to "#{weapon.name} / #{weapon.price}コル / #{weapon.weapon_type}", game_path(panel: "blacksmith", blacksmith_menu: "buy", weapon_name: weapon.name), class: "btn btn-outline-warning w-100" %>
            <% end %>
          </div>
        <% else %>
          <p class="mb-0">この町の鍛冶屋には販売武器がありません。</p>
        <% end %>
      <% elsif blacksmith_menu == "repair" %>
        <% if equipped_weapon %>
          <p class="mb-1">対象: <%= equipped_weapon.display_name %></p>
          <p class="mb-1">耐久力: <%= equipped_weapon.durability %> / <%= equipped_weapon.max_durability %></p>
          <p class="mb-2">費用: <%= equipped_weapon.repair_cost %>コル</p>
          <%= button_to "整備する", blacksmith_path, method: :post, class: "btn btn-outline-warning w-100" %>
        <% else %>
          <p class="mb-0">整備できる装備中の武器がありません。</p>
        <% end %>
      <% elsif blacksmith_menu == "upgrade" %>
        <% selected_weapon = @player.weapons.find_by(id: params[:weapon_id]) %>
        <% if selected_weapon %>
          <%= link_to "強化する武器一覧に戻る", game_path(panel: "blacksmith", blacksmith_menu: "upgrade"), class: "btn btn-outline-light w-100 mb-3" %>
          <% upgrade_recipe = WeaponUpgradeService.recipe_for(selected_weapon) %>
          <h6><%= selected_weapon.display_name %></h6>
          <p class="mb-1">現在攻撃力: <%= selected_weapon.effective_attack_power %></p>
          <p class="mb-1">強化後: +<%= selected_weapon.enhancement_level.to_i + 1 %></p>
          <p class="mb-1">必要素材: <%= upgrade_recipe&.required_materials&.map { |name, count| "#{name} ×#{count}" }&.join("、") || "硬い甲殻 ×1" %></p>
          <p class="mb-2">必要コル: <%= upgrade_recipe&.required_col.to_i %></p>
          <%= button_to "強化する", upgrade_weapon_path(weapon_id: selected_weapon.id), method: :post, class: "btn btn-outline-warning w-100" %>
        <% elsif @player.weapons.any? %>
          <div class="d-grid gap-2">
            <% @player.weapons.each do |weapon| %>
              <%= link_to "#{weapon.display_name} / 攻撃力 #{weapon.effective_attack_power}", game_path(panel: "blacksmith", blacksmith_menu: "upgrade", weapon_id: weapon.id), class: "btn btn-outline-warning w-100" %>
            <% end %>
          </div>
        <% else %>
          <p class="mb-0">強化できる武器がありません。</p>
        <% end %>
      <% elsif blacksmith_menu == "evolve" %>
        <% selected_weapon = @player.weapons.find_by(id: params[:weapon_id]) %>
        <% rule = WeaponEvolutionRule.find_by(source_weapon_name: selected_weapon&.name) %>
        <% if selected_weapon && rule %>
          <%= link_to "進化する武器一覧に戻る", game_path(panel: "blacksmith", blacksmith_menu: "evolve"), class: "btn btn-outline-light w-100 mb-3" %>
          <h6><%= selected_weapon.display_name %></h6>
          <p class="mb-1">進化先: <%= rule.target_weapon_name %></p>
          <p class="mb-1">必要強化値: +<%= rule.required_enhancement_level %></p>
          <p class="mb-2">必要Lv: <%= rule.required_player_level %></p>
          <%= button_to "進化する", evolve_weapon_path(weapon_id: selected_weapon.id), method: :post, class: "btn btn-outline-warning w-100" %>
        <% else %>
          <div class="d-grid gap-2">
            <% @player.weapons.each do |weapon| %>
              <% next unless WeaponEvolutionRule.exists?(source_weapon_name: weapon.name) %>
              <%= link_to weapon.display_name, game_path(panel: "blacksmith", blacksmith_menu: "evolve", weapon_id: weapon.id), class: "btn btn-outline-warning w-100" %>
            <% end %>
          </div>
        <% end %>
      <% elsif blacksmith_menu == "sell" %>
        <% sellable_weapons = @player.weapons.select(&:sellable_by_player?) %>
        <% if sellable_weapons.any? %>
          <div class="d-grid gap-2">
            <% sellable_weapons.each do |weapon| %>
              <div class="border rounded p-2">
                <p class="mb-1"><%= weapon.display_name %></p>
                <p class="mb-1">攻撃力: <%= weapon.effective_attack_power %> / 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                <p class="mb-2">売却額: <%= weapon.sell_price %>コル</p>
                <% if weapon.unique_item? && params[:confirm_weapon_id].to_i != weapon.id %>
                  <%= link_to "売却確認へ", game_path(panel: "blacksmith", blacksmith_menu: "sell", confirm_weapon_id: weapon.id), class: "btn btn-outline-danger w-100" %>
                <% else %>
                  <% if weapon.unique_item? %>
                    <p class="text-danger small mb-2">この武器は二度と手に入らないかもしれません。本当に売却しますか？</p>
                  <% end %>
                  <%= button_to "売却する", sell_weapon_path(weapon_id: weapon.id, confirm_unique: weapon.unique_item? ? "1" : nil), method: :post, class: "btn btn-outline-warning w-100" %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="mb-0">売却できる武器がありません。</p>
        <% end %>
      <% else %>
        <p class="mb-0">左のメニューから行動を選択してください。</p>
      <% end %>
      </div>
    <% end %>
  </div>
<% else %>
<div class="d-grid gap-2">
  <% if @player.field_route.present? %>
    <% route = @player.field_route %>
    <div class="d-flex gap-2">
      <%= button_to "探索", explore_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-primary btn-lg w-100" %>
      <%= button_to "狩り", hunt_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-danger btn-lg w-100" %>
      <%= button_to "採取", gather_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-success btn-lg w-100" %>
      <%= button_to "休憩", start_rest_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-light btn-lg w-100" %>
    </div>

  <% elsif @player.location&.safe_area? %>
    <%= button_to "街を散策する", stroll_path, method: :post, class: "btn btn-primary btn-lg" %>

    <h5 class="mt-3">施設</h5>

    <% town_discovery = @town_discovery || @player.town_discovery_for %>
    <% if town_discovery&.found_inn? %>
      <%= link_to "宿屋に入る", game_path(panel: "inn"), class: "btn btn-outline-success w-100" %>
    <% end %>

    <% if town_discovery&.found_item_shop? %>
      <%= link_to "道具屋に入る", game_path(panel: "item_shop"), class: "btn btn-outline-warning w-100" %>
    <% end %>

    <% if town_discovery&.found_blacksmith? %>
      <%= link_to "鍛冶屋に入る", game_path(panel: "blacksmith"), class: "btn btn-outline-warning w-100" %>
    <% end %>
  <% else %>
    <div class="d-flex gap-2">
      <%= button_to "探索", explore_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-primary btn-lg w-100" %>
      <%= button_to "狩り", hunt_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-danger btn-lg w-100" %>
      <%= button_to "採取", gather_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-success btn-lg w-100" %>
      <%= button_to "休憩", start_rest_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-light btn-lg w-100" %>
    </div>
    <% if @available_treasures.present? %>
      <h5 class="mt-3">発見済み宝箱</h5>
      <div class="d-grid gap-2">
        <% @available_treasures.each do |treasure| %>
          <%= button_to "#{treasure.name}を開ける",
              open_treasure_path(treasure_chest_id: treasure.id),
              method: :post,
              class: "btn btn-outline-warning w-100" %>
        <% end %>
      </div>
    <% end %>
    <% if @available_bosses.present? %>
      <h5 class="mt-3">発見済みボス</h5>
      <div class="d-grid gap-2">
        <% @available_bosses.each do |boss| %>
          <%= button_to "#{boss.name}に挑む",
              challenge_boss_path(mob_id: boss.id),
              method: :post,
              class: boss.boss_type == "field_boss" ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <% if @player.field_route.present? %>
    <% if @available_treasures.present? %>
      <h5 class="mt-3">発見済み宝箱</h5>
      <div class="d-grid gap-2">
        <% @available_treasures.each do |treasure| %>
          <%= button_to "#{treasure.name}を開ける",
              open_treasure_path(treasure_chest_id: treasure.id),
              method: :post,
              class: "btn btn-outline-warning w-100" %>
        <% end %>
      </div>
    <% end %>
    <% if @available_bosses.present? %>
      <h5 class="mt-3">発見済みボス</h5>
      <div class="d-grid gap-2">
        <% @available_bosses.each do |boss| %>
          <%= button_to "#{boss.name}に挑む",
              challenge_boss_path(mob_id: boss.id),
              method: :post,
              class: boss.boss_type == "field_boss" ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <h5 class="mt-3">移動</h5>

  <% if @player.field_route.present? %>
    <% route = @player.field_route %>
    <% route_progress = @player.player_route_progresses.find_by(route: route) %>
    <% destination_discovered = FieldService.destination_discovered?(@player, route) %>
    <% destination_reached = route_progress&.reached_destination? %>
    <% next_discovered_area = FieldService.next_discovered_area_for(@player, route) %>

    <div class="mb-2">
      <%= button_to "#{route.from_location.name}方面へ戻る",
          move_path(route_id: route.id, direction: "backward"),
          method: :post,
          class: "btn btn-outline-warning w-100 mb-1" %>

      <% if destination_discovered %>
        <%= button_to "#{route.to_location.name}方面へ進む",
            move_path(route_id: route.id, direction: "forward"),
            method: :post,
            class: "btn btn-outline-info w-100 mb-2" %>
      <% elsif next_discovered_area %>
        <%= button_to "探索済みのエリア（#{next_discovered_area.name}）まで進む",
            move_path(route_id: route.id, direction: "area"),
            method: :post,
            class: "btn btn-outline-info w-100 mb-2" %>
      <% end %>

      <% unless destination_discovered %>
        <div class="small text-secondary mb-2">周辺を探索して道筋を探そう</div>
      <% end %>
    </div>

  <% else %>
    <% @routes.each do |route| %>
      <%= button_to "#{route.name}へ出る",
          move_path(route_id: route.id),
          method: :post,
          class: "btn btn-outline-info w-100 mb-2" %>
    <% end %>
  <% end %>
</div>
<% end %>



