          <% else %>
            <% facility_panel_open = selected_panel.in?(%w[inn item_shop blacksmith equipment items]) && @player.location&.safe_area? %>
            <% if facility_panel_open %>
              <div class="card bg-secondary text-light mb-3">
                <% if selected_panel == "items" %>

                  <div class="card-header">所持品一覧</div>
                  <div class="card-body">

                    <% if params[:item_category] == "weapons" %>

                      <% @player.weapons.each do |weapon| %>
                        <div class="border rounded mb-2">
                          <button class="btn btn-dark w-100 text-start"
                                  type="button"
                                  data-bs-toggle="collapse"
                                  data-bs-target="#weapon-item-<%= weapon.id %>">

                            <%= weapon.display_name %>
                            <% if weapon.equipped? %>（装備中）<% end %>

                          </button>

                          <div class="collapse p-2"
                              id="weapon-item-<%= weapon.id %>">

                            <p>攻撃力: <%= weapon.attack_power %></p>
                            <p>耐久力: <%= weapon.durability %>/<%= weapon.max_durability %></p>

                            <% unless weapon.equipped? %>
                              <%= button_to "装備する",
                                  equip_weapon_path(weapon_id: weapon.id),
                                  method: :post,
                                  class: "btn btn-outline-warning w-100" %>
                            <% end %>
                          </div>
                        </div>
                      <% end %>

                    <% elsif params[:item_category] == "armors" %>

                      <% @player.armors.each do |armor| %>

                        <div class="border rounded mb-2">
                          <button class="btn btn-dark w-100 text-start"
                                  type="button"
                                  data-bs-toggle="collapse"
                                  data-bs-target="#armor-item-<%= armor.id %>">

                            <%= armor.name %>
                            <% if armor.equipped? %>（装備中）<% end %>

                          </button>

                          <div class="collapse p-2"
                              id="armor-item-<%= armor.id %>">

                            <p>防御力: <%= armor.defense %></p>
                            <p>重量: <%= armor.weight %></p>

                          </div>
                        </div>

                      <% end %>

                    <% elsif params[:item_category].in?(%w[healing gathered drop]) %>

                      <% items = @player.items.where(category: params[:item_category])
                                              .where("quantity > 0")
                                              .order(:name) %>

                      <% items.each do |item| %>

                        <div class="border rounded mb-2">

                          <button class="btn btn-dark w-100 text-start"
                                  type="button"
                                  data-bs-toggle="collapse"
                                  data-bs-target="#item-right-<%= item.id %>">

                            <%= item.name %> × <%= item.quantity %>

                          </button>

                          <div class="collapse p-2"
                              id="item-right-<%= item.id %>">

                            <% if item.category == "healing" %>
                              <%= button_to "使う",
                                  use_item_path(item_name: item.name),
                                  method: :post,
                                  class: "btn btn-outline-success w-100 mb-2" %>
                            <% end %>

                            <% if item.discardable_by_player? %>
                              <%= button_to "全部捨てる",
                                  discard_item_path(
                                    item_id: item.id,
                                    quantity: item.quantity
                                  ),
                                  method: :post,
                                  class: "btn btn-outline-danger w-100" %>
                            <% end %>

                          </div>

                        </div>

                      <% end %>

                    <% end %>

                  </div>

                <% elsif selected_panel == "equipment" %>
                  <div class="card-header">所持装備</div>
                  <div class="card-body">
                    <h6>所持武器</h6>

                    <% @player.weapons.each do |weapon| %>
                      <div class="border rounded mb-2">
                        <button class="btn btn-dark w-100 text-start"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#weapon-<%= weapon.id %>">
                          <%= weapon.display_name %>
                          <% if weapon.equipped? %>（装備中）<% end %>
                          <% if weapon.favorite? %> ★<% end %>
                        </button>

                        <div class="collapse p-2" id="weapon-<%= weapon.id %>">
                          <p class="mb-1">攻撃力: <%= weapon.attack_power %></p>
                          <p class="mb-1">耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                          <p class="mb-1">クリティカル率: <%= weapon.critical_rate %>%</p>

                          <% unless weapon.equipped? %>
                            <%= button_to "装備する", equip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-warning w-100 mt-2" %>
                          <% else %>
                            <%= button_to "取り外す", unequip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
                          <% end %>
                          <%= button_to weapon.favorite? ? "★ お気に入り解除" : "☆ お気に入り登録",
                              toggle_weapon_favorite_path(weapon_id: weapon.id),
                              method: :post,
                              class: "btn btn-outline-light w-100 mt-2" %>
                        </div>
                      </div>
                    <% end %>

                    <h6 class="mt-3">所持防具</h6>

                    <% @player.armors.each do |armor| %>
                      <div class="border rounded mb-2">
                        <button class="btn btn-dark w-100 text-start"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#armor-<%= armor.id %>">
                          <%= armor.name %>
                          <% if armor.equipped? %>（装備中）<% end %>
                          <% if armor.favorite? %> ★<% end %>
                        </button>

                        <div class="collapse p-2" id="armor-<%= armor.id %>">
                          <p class="mb-1">部位: <%= armor.slot_name %></p>
                          <p class="mb-1">防御: <%= armor.defense %></p>
                          <p class="mb-1">重量: <%= armor.weight %></p>

                          <% if armor.equipped? %>
                            <%= button_to "取り外す", unequip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
                          <% else %>
                            <%= button_to "装備する", equip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-info w-100 mt-2" %>
                          <% end %>
                          <%= button_to armor.favorite? ? "★ お気に入り解除" : "☆ お気に入り登録",
                              toggle_armor_favorite_path(armor_id: armor.id),
                              method: :post,
                              class: "btn btn-outline-light w-100 mt-2" %>
                        </div>
                      </div>
                    <% end %>
                  </div>

                <% elsif selected_panel == "inn" %>
                  <% inn_menu = params[:inn_menu].presence || "rest" %>
                  <% inn_cost = @player.location&.name == "ホルンカの村" ? 50 : 0 %>
                  <% current_base = @player.player_bases.find_by(location: @player.location, base_type: "home", active: true) %>

                  <div class="card-header">宿屋</div>
                  <div class="card-body">

                    <% if inn_menu == "rest" %>
                      <h6>休憩</h6>
                      <p>宿屋で休憩してHPを回復します。</p>
                      <%= button_to "休憩する（#{inn_cost}コル）", inn_path, method: :post, class: "btn btn-outline-success w-100" %>

                    <% elsif inn_menu == "base" %>
                      <h6>本拠点</h6>

                      <% if @player.home_base %>
                        <p>現在の本拠点: <%= @player.home_base.location.name %></p>
                      <% else %>
                        <p>本拠点は未設定です。</p>
                      <% end %>

                      <% if @player.home_base&.location_id != @player.location_id %>
                        <% if params[:confirm_home_base] == "1" %>
                          <div class="border border-info rounded p-2">
                            <p class="mb-2">ここを本拠点にしますか？</p>
                            <div class="d-flex gap-2">
                              <%= button_to "はい", set_home_base_path(confirm: "1"), method: :post, form: { class: "flex-fill" }, class: "btn btn-info w-100" %>
                              <%= link_to "いいえ", game_path(panel: "inn", inn_menu: "base"), class: "btn btn-outline-light flex-fill" %>
                            </div>
                          </div>
                        <% else %>
                          <%= link_to "この宿屋を本拠点にする", game_path(panel: "inn", inn_menu: "base", confirm_home_base: "1"), class: "btn btn-outline-info w-100" %>
                        <% end %>
                      <% else %>
                        <div class="text-info small text-center">現在の本拠点です</div>
                      <% end %>

                    <% elsif inn_menu == "col" %>
                      <h6>所持金管理</h6>

                      <% if current_base %>
                        <p>預け金: <%= @player.base_col.to_i %>コル</p>

                        <%= form_with url: deposit_base_col_path, method: :post, class: "d-grid gap-2 mb-3" do %>
                          <%= number_field_tag :amount, 100, min: 1, max: @player.col.to_i, class: "form-control form-control-sm" %>
                          <%= submit_tag "コルを預ける", class: "btn btn-outline-info w-100" %>
                        <% end %>

                        <%= form_with url: withdraw_base_col_path, method: :post, class: "d-grid gap-2" do %>
                          <%= number_field_tag :amount, 100, min: 1, max: @player.base_col.to_i, class: "form-control form-control-sm" %>
                          <%= submit_tag "コルを引き出す", class: "btn btn-outline-light w-100" %>
                        <% end %>
                      <% else %>
                        <p class="text-secondary small mb-0">この宿屋を本拠点にすると、所持金管理を使えます。</p>
                      <% end %>

                    <% elsif inn_menu == "storage" %>
                      <h6>アイテム収納</h6>

                      <% if current_base %>
                        <% storage_tab = params[:storage_tab].presence || "store" %>
                        <% item_category = params[:item_category].presence %>

                        <ul class="nav nav-tabs mb-2">
                          <li class="nav-item">
                            <%= link_to "預ける", game_path(panel: "inn", inn_menu: "storage", storage_tab: "store", item_category: item_category), class: "nav-link #{storage_tab == 'store' ? 'active' : ''}" %>
                          </li>
                          <li class="nav-item">
                            <%= link_to "取り出す", game_path(panel: "inn", inn_menu: "storage", storage_tab: "withdraw", item_category: item_category), class: "nav-link #{storage_tab == 'withdraw' ? 'active' : ''}" %>
                          </li>
                        </ul>

                    <div class="d-flex gap-2 mb-3 flex-wrap">
                    <%= link_to "全部",
                      game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab),
                      class: "btn btn-sm #{item_category.blank? ? 'btn-info' : 'btn-outline-light'}" %>
                      <%= link_to "回復", game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab, item_category: "healing"), class: "btn btn-sm #{item_category == 'healing' ? 'btn-info' : 'btn-outline-light'}" %>

                      <%= link_to "採取", game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab, item_category: "gathered"), class: "btn btn-sm #{item_category == 'gathered' ? 'btn-info' : 'btn-outline-light'}" %>

                      <%= link_to "ドロップ", game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab, item_category: "drop"), class: "btn btn-sm #{item_category == 'drop' ? 'btn-info' : 'btn-outline-light'}" %>
                    </div>

                        <% if storage_tab == "store" %>
                          <% carried_items = @player.items.where("quantity > 0").order(:category, :name) %>
                          <% carried_items = carried_items.where(category: item_category) if item_category.present? %>

                          <% if carried_items.any? %>
                            <div class="d-grid gap-2">
                              <% carried_items.each do |item| %>
                                <div class="border rounded">
                                  <button class="btn btn-dark w-100 text-start"
                                          type="button"
                                          data-bs-toggle="collapse"
                                          data-bs-target="#store-item-<%= item.id %>">
                                    <%= item.name %> × <%= item.quantity %>
                                  </button>

                                  <div class="collapse p-2" id="store-item-<%= item.id %>">
                                    <%= form_with url: store_item_path(item_id: item.id), method: :post, class: "d-flex gap-2 mb-2" do %>
                                      <%= number_field_tag :quantity, item.quantity, min: 1, max: item.quantity, class: "form-control form-control-sm" %>
                                      <%= submit_tag "預ける", class: "btn btn-outline-light btn-sm" %>
                                    <% end %>

                                    <%= button_to "全部預ける",
                                                  store_item_path(item_id: item.id, quantity: item.quantity),
                                                  method: :post,
                                                  class: "btn btn-outline-info btn-sm w-100" %>
                                  </div>
                                </div>
                              <% end %>
                            </div>
                          <% else %>
                            <p class="text-secondary small mb-0">預けられるアイテムはありません。</p>
                          <% end %>

                        <% else %>
                          <% storage_items = current_base.storage_items.where("quantity > 0").order(:category, :name) %>
                          <% storage_items = storage_items.where(category: item_category) if item_category.present? %>

                          <% if storage_items.any? %>
                            <div class="d-grid gap-2">
                              <% storage_items.each do |storage_item| %>
                                <div class="border rounded">
                                  <button class="btn btn-dark w-100 text-start"
                                          type="button"
                                          data-bs-toggle="collapse"
                                          data-bs-target="#withdraw-item-<%= storage_item.id %>">
                                    <%= storage_item.name %> × <%= storage_item.quantity %>
                                  </button>

                                  <div class="collapse p-2" id="withdraw-item-<%= storage_item.id %>">
                                    <%= form_with url: withdraw_item_path(storage_item_id: storage_item.id), method: :post, class: "d-flex gap-2 mb-2" do %>
                                      <%= number_field_tag :quantity, storage_item.quantity, min: 1, max: storage_item.quantity, class: "form-control form-control-sm" %>
                                      <%= submit_tag "取り出す", class: "btn btn-outline-light btn-sm" %>
                                    <% end %>

                                    <%= button_to "全部取り出す",
                                                  withdraw_item_path(storage_item_id: storage_item.id, quantity: storage_item.quantity),
                                                  method: :post,
                                                  class: "btn btn-outline-info btn-sm w-100" %>
                                  </div>
                                </div>
                              <% end %>
                            </div>
                          <% else %>
                            <p class="text-secondary small mb-0">収納中のアイテムはありません。</p>
                          <% end %>
                        <% end %>

                      <% else %>
                        <p class="text-secondary small mb-0">
                          この宿屋を本拠点にすると、アイテム収納を使えます。
                        </p>
                      <% end %>
                    <% end %>
                  </div>
                <% elsif selected_panel == "item_shop" %>
                  <% shop_menu = params[:shop_menu].presence %>
                  <div class="card-header">道具屋</div>
                  <div class="card-body">
                    <% if shop_menu == "buy" %>
                      <% shop_items = ShopCatalog.item_shop_items(@player.location) %>
                      <% selected_shop_item = shop_items.find { |shop_item| shop_item.item_name == params[:item_name] } %>
                      <% if selected_shop_item %>
                        <h6><%= selected_shop_item.item_name %></h6>
                        <p class="mb-1">価格: <%= selected_shop_item.price %>コル</p>
                        <p class="mb-1">種別: <%= selected_shop_item.category %></p>
                        <p class="mb-1">重さ: <%= Item.new(name: selected_shop_item.item_name, category: selected_shop_item.category).weight %></p>
                        <% if selected_shop_item.item_name == "ポーション" %>
                          <p class="mb-2">効果: HPを100回復</p>
                        <% else %>
                          <p class="mb-2">効果: 使用効果なし</p>
                        <% end %>
                        <%= button_to "購入する", item_shop_path(item_name: selected_shop_item.item_name), method: :post, class: "btn btn-warning w-100" %>
                      <% elsif shop_items.any? %>
                        <div class="d-grid gap-2">
                          <% shop_items.each do |shop_item| %>
                            <%= link_to "#{shop_item.item_name} / #{shop_item.price}コル / #{shop_item.category}",
                                game_path(panel: "item_shop", shop_menu: "buy", item_name: shop_item.item_name),
                                class: "btn btn-outline-warning w-100" %>
                          <% end %>
                        </div>
                      <% else %>
                        <p class="mb-0">この町の道具屋には販売品がありません。</p>
                      <% end %>
                    <% elsif shop_menu == "produce" %>
                      <% herb = @player.items.find_by(name: "薬草", category: "gathered") || @player.items.find_by(name: "薬草") %>
                      <h6>ポーション</h6>
                      <p class="mb-1">必要素材: 薬草 10個</p>
                      <p class="mb-1">費用: 20コル</p>
                      <p class="mb-2">所持薬草: <%= (herb&.quantity || 0).to_i %></p>
                      <%= button_to "ポーションを生産する", produce_item_path, method: :post, class: "btn btn-outline-warning w-100" %>
                    <% elsif shop_menu == "sell" %>
                      <% sellable_items = @player.items.select { |item| item.quantity.to_i.positive? && (item.sellable_by_player? || item.unique_item?) } %>
                      <% if sellable_items.any? %>
                        <div class="d-grid gap-2">
                          <% sellable_items.each do |item| %>
                            <div class="border rounded p-2">
                              <p class="mb-1"><%= item.name %> × <%= item.quantity %></p>
                              <p class="mb-2">売却価格: <%= item.sell_price %>コル</p>
                              <% if item.unique_item? && params[:confirm_item_id].to_i != item.id %>
                                <%= link_to "売却確認へ", game_path(panel: "item_shop", shop_menu: "sell", confirm_item_id: item.id), class: "btn btn-outline-danger w-100" %>
                              <% else %>
                                <% if item.unique_item? %>
                                  <p class="text-danger small mb-2">このアイテムは二度と手に入らないかもしれません。本当に売却しますか？</p>
                                <% end %>
                                <%= button_to "1つ売却する", sell_item_path(item_name: item.name, confirm_unique: item.unique_item? ? "1" : nil), method: :post, class: "btn btn-outline-warning w-100" %>
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                      <% else %>
                        <p class="mb-0">売却できるアイテムがありません。</p>
                      <% end %>
                    <% else %>
                      <p class="mb-0">左のメニューから行動を選択してください。</p>
                    <% end %>
                  </div>
                <% elsif selected_panel == "blacksmith" %>
                  <% blacksmith_menu = params[:blacksmith_menu].presence %>
                  <div class="card-header">鍛冶屋</div>
                  <div class="card-body">
                  <% if blacksmith_menu == "buy" %>
                    <% shop_weapons = ShopCatalog.blacksmith_weapons(@player.location) %>
                    <% selected_shop_weapon = shop_weapons.find { |weapon| weapon.name == params[:weapon_name] } %>
                    <% if selected_shop_weapon %>
                      <h6><%= selected_shop_weapon.name %></h6>
                      <p class="mb-1">価格: <%= selected_shop_weapon.price %>コル</p>
                      <p class="mb-1">武器種: <%= selected_shop_weapon.weapon_type %></p>
                      <p class="mb-1">攻撃力: <%= selected_shop_weapon.attack_power %></p>
                      <p class="mb-1">攻撃属性: <%= selected_shop_weapon.attack_attributes %></p>
                      <p class="mb-1">耐久力: <%= selected_shop_weapon.durability %> / <%= selected_shop_weapon.max_durability %></p>
                      <p class="mb-1">重さ: <%= selected_shop_weapon.weight %></p>
                      <p class="mb-1">参照ステータス: 筋力<%= selected_shop_weapon.strength_ratio %>% / 敏捷<%= selected_shop_weapon.agility_ratio %>%</p>
                      <p class="mb-1">補正: HP +<%= selected_shop_weapon.hp_bonus %> / 筋力 +<%= selected_shop_weapon.strength_bonus %> / 敏捷 +<%= selected_shop_weapon.agility_bonus %></p>
                      <% if selected_shop_weapon.description.present? %>
                        <p class="mb-2"><%= selected_shop_weapon.description %></p>
                      <% end %>
                      <%= button_to "購入する", buy_bronze_sword_path(weapon_name: selected_shop_weapon.name), method: :post, class: "btn btn-warning w-100" %>
                    <% elsif shop_weapons.any? %>
                      <div class="d-grid gap-2">
                        <% shop_weapons.each do |weapon| %>
                          <%= link_to "#{weapon.name} / #{weapon.price}コル / #{weapon.weapon_type}", game_path(panel: "blacksmith", blacksmith_menu: "buy", weapon_name: weapon.name), class: "btn btn-outline-warning w-100" %>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="mb-0">この町の鍛冶屋には販売武器がありません。</p>
                    <% end %>
                  <% elsif blacksmith_menu == "repair" %>
                    <% if equipped_weapon %>
                      <p class="mb-1">対象: <%= equipped_weapon.display_name %></p>
                      <p class="mb-1">耐久力: <%= equipped_weapon.durability %> / <%= equipped_weapon.max_durability %></p>
                      <p class="mb-2">費用: <%= equipped_weapon.repair_cost %>コル</p>
                      <%= button_to "整備する", blacksmith_path, method: :post, class: "btn btn-outline-warning w-100" %>
                    <% else %>
                      <p class="mb-0">整備できる装備中の武器がありません。</p>
                    <% end %>
                  <% elsif blacksmith_menu == "upgrade" %>
                    <% selected_weapon = @player.weapons.find_by(id: params[:weapon_id]) %>
                    <% if selected_weapon %>
                      <% upgrade_recipe = WeaponUpgradeService.recipe_for(selected_weapon) %>
                      <h6><%= selected_weapon.display_name %></h6>
                      <p class="mb-1">現在攻撃力: <%= selected_weapon.effective_attack_power %></p>
                      <p class="mb-1">強化後: +<%= selected_weapon.enhancement_level.to_i + 1 %></p>
                      <p class="mb-1">必要素材: <%= upgrade_recipe&.required_materials&.map { |name, count| "#{name} ×#{count}" }&.join("、") || "硬い甲殻 ×1" %></p>
                      <p class="mb-2">必要コル: <%= upgrade_recipe&.required_col.to_i %></p>
                      <%= button_to "強化する", upgrade_weapon_path(weapon_id: selected_weapon.id), method: :post, class: "btn btn-outline-warning w-100" %>
                    <% elsif @player.weapons.any? %>
                      <div class="d-grid gap-2">
                        <% @player.weapons.each do |weapon| %>
                          <%= link_to "#{weapon.display_name} / 攻撃力 #{weapon.effective_attack_power}", game_path(panel: "blacksmith", blacksmith_menu: "upgrade", weapon_id: weapon.id), class: "btn btn-outline-warning w-100" %>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="mb-0">強化できる武器がありません。</p>
                    <% end %>
                  <% elsif blacksmith_menu == "evolve" %>
                    <% selected_weapon = @player.weapons.find_by(id: params[:weapon_id]) %>
                    <% rule = WeaponEvolutionRule.find_by(source_weapon_name: selected_weapon&.name) %>
                    <% if selected_weapon && rule %>
                      <h6><%= selected_weapon.display_name %></h6>
                      <p class="mb-1">進化先: <%= rule.target_weapon_name %></p>
                      <p class="mb-1">必要強化値: +<%= rule.required_enhancement_level %></p>
                      <p class="mb-2">必要Lv: <%= rule.required_player_level %></p>
                      <%= button_to "進化する", evolve_weapon_path(weapon_id: selected_weapon.id), method: :post, class: "btn btn-outline-warning w-100" %>
                    <% else %>
                      <div class="d-grid gap-2">
                        <% @player.weapons.each do |weapon| %>
                          <% next unless WeaponEvolutionRule.exists?(source_weapon_name: weapon.name) %>
                          <%= link_to weapon.display_name, game_path(panel: "blacksmith", blacksmith_menu: "evolve", weapon_id: weapon.id), class: "btn btn-outline-warning w-100" %>
                        <% end %>
                      </div>
                    <% end %>
                  <% elsif blacksmith_menu == "sell" %>
                    <% sellable_weapons = @player.weapons.select(&:sellable_by_player?) %>
                    <% if sellable_weapons.any? %>
                      <div class="d-grid gap-2">
                        <% sellable_weapons.each do |weapon| %>
                          <div class="border rounded p-2">
                            <p class="mb-1"><%= weapon.display_name %></p>
                            <p class="mb-1">攻撃力: <%= weapon.effective_attack_power %> / 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                            <p class="mb-2">売却額: <%= weapon.sell_price %>コル</p>
                            <% if weapon.unique_item? && params[:confirm_weapon_id].to_i != weapon.id %>
                              <%= link_to "売却確認へ", game_path(panel: "blacksmith", blacksmith_menu: "sell", confirm_weapon_id: weapon.id), class: "btn btn-outline-danger w-100" %>
                            <% else %>
                              <% if weapon.unique_item? %>
                                <p class="text-danger small mb-2">この武器は二度と手に入らないかもしれません。本当に売却しますか？</p>
                              <% end %>
                              <%= button_to "売却する", sell_weapon_path(weapon_id: weapon.id, confirm_unique: weapon.unique_item? ? "1" : nil), method: :post, class: "btn btn-outline-warning w-100" %>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="mb-0">売却できる武器がありません。</p>
                    <% end %>
                  <% else %>
                    <p class="mb-0">左のメニューから行動を選択してください。</p>
                  <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
            <div class="d-grid gap-2">
              <% if @player.field_route.present? %>
                <% route = @player.field_route %>
                <div class="d-flex gap-2">
                  <%= button_to "探索", explore_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-primary btn-lg w-100" %>
                  <%= button_to "狩り", hunt_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-danger btn-lg w-100" %>
                  <%= button_to "採取", gather_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-success btn-lg w-100" %>
                  <%= button_to "休憩", start_rest_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-light btn-lg w-100" %>
                </div>

              <% elsif @player.location&.safe_area? %>
                <%= button_to "街を散策する", stroll_path, method: :post, class: "btn btn-primary btn-lg" %>

                <h5 class="mt-3">施設</h5>

                <% town_discovery = @town_discovery || @player.town_discovery_for %>
                <% if town_discovery&.found_inn? %>
                  <%= link_to "宿屋に入る", game_path(panel: "inn"), class: "btn btn-outline-success w-100" %>
                <% end %>

                <% if town_discovery&.found_item_shop? %>
                  <%= link_to "道具屋に入る", game_path(panel: "item_shop"), class: "btn btn-outline-warning w-100" %>
                <% end %>

                <% if town_discovery&.found_blacksmith? %>
                  <%= link_to "鍛冶屋に入る", game_path(panel: "blacksmith"), class: "btn btn-outline-warning w-100" %>
                <% end %>
              <% else %>
                <div class="d-flex gap-2">
                  <%= button_to "探索", explore_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-primary btn-lg w-100" %>
                  <%= button_to "狩り", hunt_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-danger btn-lg w-100" %>
                  <%= button_to "採取", gather_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-success btn-lg w-100" %>
                  <%= button_to "休憩", start_rest_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-light btn-lg w-100" %>
                </div>
                <% if @available_treasures.present? %>
                  <h5 class="mt-3">発見済み宝箱</h5>
                  <div class="d-grid gap-2">
                    <% @available_treasures.each do |treasure| %>
                      <%= button_to "#{treasure.name}を開ける",
                          open_treasure_path(treasure_chest_id: treasure.id),
                          method: :post,
                          class: "btn btn-outline-warning w-100" %>
                    <% end %>
                  </div>
                <% end %>
                <% if @available_bosses.present? %>
                  <h5 class="mt-3">発見済みボス</h5>
                  <div class="d-grid gap-2">
                    <% @available_bosses.each do |boss| %>
                      <%= button_to "#{boss.name}に挑む",
                          challenge_boss_path(mob_id: boss.id),
                          method: :post,
                          class: boss.boss_type == "field_boss" ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
                    <% end %>
                  </div>
                <% end %>
              <% end %>

              <h5 class="mt-3">移動</h5>

              <% if @player.field_route.present? %>
                <% route = @player.field_route %>
                <% route_progress = @player.player_route_progresses.find_by(route: route) %>
                <% destination_discovered = FieldService.destination_discovered?(@player, route) %>
                <% destination_reached = route_progress&.reached_destination? %>
                <% next_discovered_area = FieldService.next_discovered_area_for(@player, route) %>

                <div class="mb-2">
                  <%= button_to "#{route.from_location.name}方面へ戻る",
                      move_path(route_id: route.id, direction: "backward"),
                      method: :post,
                      class: "btn btn-outline-warning w-100 mb-1" %>

                  <% if destination_discovered %>
                    <%= button_to "#{route.to_location.name}方面へ進む",
                        move_path(route_id: route.id, direction: "forward"),
                        method: :post,
                        class: "btn btn-outline-info w-100 mb-2" %>
                  <% elsif next_discovered_area %>
                    <%= button_to "探索済みのエリア（#{next_discovered_area.name}）まで進む",
                        move_path(route_id: route.id, direction: "area"),
                        method: :post,
                        class: "btn btn-outline-info w-100 mb-2" %>
                  <% end %>

                  <% unless destination_discovered %>
                    <div class="small text-secondary mb-2">周辺を探索して道筋を探そう</div>
                  <% end %>
                </div>

              <% else %>
                <% @routes.each do |route| %>
                  <%= button_to "#{route.name}へ出る",
                      move_path(route_id: route.id),
                      method: :post,
                      class: "btn btn-outline-info w-100 mb-2" %>
                <% end %>
              <% end %>
            </div>
            <% end %>
          <% end %>
