                    <%= link_to "施設から出る", game_path, class: "btn btn-outline-light w-100" %>
                  </div>
                <% end %>
              <% elsif selected_panel == "blacksmith" %>
                <% blacksmith_menu = params[:blacksmith_menu].presence %>
                <h5>鍛冶屋</h5>
                <% unless @player.town_discovery_for&.found_blacksmith? %>
                  <p class="mb-0">鍛冶屋はまだ見つけていません。</p>
                <% else %>
                  <div class="d-grid gap-2 mb-3">
                    <%= link_to "武器を購入する", game_path(panel: "blacksmith", blacksmith_menu: "buy"), class: "btn btn-outline-warning w-100" %>
