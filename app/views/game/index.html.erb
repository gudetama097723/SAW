<div class="container py-4">
  <div class="card bg-dark text-light border-secondary shadow-lg">
    <div class="card-header text-center">
      <h1 class="mb-0">Sword Art World</h1>
      <div class="d-flex align-items-start gap-4">
        <div><h2>第1層</h2></div>
        <div>
          <div>フィールド名: <%= @player.field_route ? "#{@player.field_route.name}（移動中）" : (@player.location&.name || "不明") %></div>
          <% if @current_field_area %>
            <div class="small text-light">全体踏破度 <%= @player.field_route_mapping_progress %>%</div>
          <% end %>
        </div>
        <% if @player.field_route.present? %>
          <div>
            <div>現在地: <%= @current_field_area&.name || "不明" %></div>
            <div class="small text-light">
              エリア踏破度 <%= @current_field_area_progress&.mapping_progress.to_i %>%
            </div>
          </div>
        <% end %>

        <div class="ms-auto"><%= @player.formatted_datetime %></div>

      </div>
    </div>

    <div class="card-body">
      <div class="message-window mb-3 p-0 text-start overflow-auto" style="min-height: 6rem; max-height: 10rem;">
        <% message_text = alert.presence || notice.presence %>
        <% message_class = alert.present? ? "text-warning" : "text-success" %>
        <div class="message-line <%= message_text.present? ? "" : "text-secondary" %>" style="line-height: 1.35;">
          <% if message_text.present? %>
            <% message_text.to_s.split(/(\[enemy\].*?\[\/enemy\]|\[mapping\].*?\[\/mapping\])/m).each do |segment| %><% if segment.start_with?("[enemy]") %><span class="text-danger"><%= segment.delete_prefix("[enemy]").delete_suffix("[/enemy]") %></span><% elsif segment.start_with?("[mapping]") %><span class="text-info"><%= segment.delete_prefix("[mapping]").delete_suffix("[/mapping]") %></span><% else %><span class="<%= message_class %>"><%= segment %></span><% end %><% end %>
          <% else %>
            メッセージはありません。
          <% end %>
        </div>
      </div>

      <% selected_panel = params[:panel].presence %>
      <% equipped_weapon = @player.equipped_weapon %>
      <% equipped_weapons = @player.equipped_weapons %>
      <% current_time = @player.current_time.to_i %>

      <div class="row">
        <div class="col-md-4">
          <div class="card bg-secondary text-light mb-3">
            <div class="card-header">ステータス</div>
            <div class="card-body">
              <div class="d-flex gap-3 align-items-center">
                <p>名前: <%= @player.name %></p>
                <p>Lv: <%= @player.level.to_i %></p>
                <% if @player.home_base %>
                  <p class="ms-auto">本拠点: <%= @player.home_base.location.name %></p>
                <% end %>
              </div>
              <p>HP: <%= @player.hp %> / <%= @player.effective_max_hp %></p>
              <div class="progress mb-2">
                <div class="progress-bar bg-success" style="width: <%= [[@player.hp.to_i * 100 / [@player.effective_max_hp, 1].max, 0].max, 100].min %>%"></div>
              </div>
              <p>経験値: <%= @player.exp.to_i %> / <%= @player.exp_to_next_level %></p>
              <div class="progress mb-2" style="height: 6px;">
                <div class="progress-bar bg-info" style="width: <%= [[@player.exp.to_i * 100 / [@player.exp_to_next_level, 1].max, 0].max, 100].min %>%"></div>
              </div>
              <% if equipped_weapons.any? %>
                <% equipped_weapons.each do |weapon| %>
                  <p class="mb-1"><%= weapon.display_name %> 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                <% end %>
              <% end %>
              <p>スキルスロット: <%= @player.used_skill_slots %> / <%= @player.skill_slots.to_i %></p>
              <p>コル: <%= @player.col %></p>
              <p>所持重量: <%= number_with_precision(@player.carry_weight, precision: 1) %> / <%= number_with_precision(@player.max_carry_weight, precision: 1) %></p>
              <% if @player.overweight? %>
                <p class="text-warning mb-0">重量オーバー：移動速度と回避率が低下しています</p>
              <% end %>
            </div>
          </div>

          <div class="card bg-secondary text-light mb-3">
            <div class="card-header">情報コマンド</div>
            <div class="card-body d-grid gap-2">
              <% if selected_panel == "equipment" %>
                <%= link_to "閉じる", game_path, class: "btn btn-outline-danger w-100" %>
              <% else %>
                <%= link_to "装備", game_path(panel: "equipment"), class: "btn btn-outline-light w-100" %>
              <% end %>

              <% if selected_panel == "items" %>
                <%= link_to "閉じる", game_path, class: "btn btn-outline-danger w-100" %>
              <% else %>
                <%= link_to "所持品", game_path(panel: "items"), class: "btn btn-outline-light w-100" %>
              <% end %>
              <% if selected_panel == "skills" %>
                <%= link_to "閉じる", game_path, class: "btn btn-outline-danger w-100" %>
              <% else %>
                <%= link_to "スキル", game_path(panel: "skills"), class: "btn btn-outline-light w-100" %>
              <% end %>
              <% if selected_panel == "growth" %>
                <%= link_to "閉じる", game_path, class: "btn btn-outline-danger w-100" %>
              <% else %>
              <%= link_to "ステータス", game_path(panel: "growth"), class: @player.stat_points.to_i.positive? ? "btn btn-warning w-100" : "btn btn-outline-light w-100" %>
              <% end %>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card bg-secondary text-light mb-3">
            <div class="card-header"><%= @battle.present? ? "戦闘コマンド" : "情報" %></div>
            <div class="card-body">
                <% if @battle.present? %>
                  <% battle_command = params[:battle_command].presence %>
                  <% battle_enemies = @battle_enemies.presence || @battle.alive_enemies.to_a %>
                  <% selected_enemy = battle_enemies.find { |enemy| enemy.id == params[:target_enemy_id].to_i } || battle_enemies.first %>
                  <% selected_parts = selected_enemy ? BattleService.ensure_mob_parts!(selected_enemy.mob) : [] %>
                  <% selected_part_states = selected_enemy ? (@part_states_by_enemy || {})[selected_enemy.id] || {} : {} %>

                <div class="d-grid gap-2 mb-3">
                  <%= link_to "通常攻撃", game_path(battle_command: "attack"), class: "btn btn-outline-warning w-100" %>
                  <% if equipped_weapon %>
                    <%= link_to "ソードスキル", game_path(battle_command: "sword_skill"), class: "btn btn-outline-danger w-100" %>
                  <% else %>
                    <div class="btn btn-outline-secondary disabled w-100">ソードスキル（武器なし）</div>
                  <% end %>
                  <%= link_to "アイテム", game_path(battle_command: "item"), class: "btn btn-outline-success w-100" %>
                  <% if !equipped_weapon && @player.weapons.where(equipped: false).any? %>
                    <%= link_to "武器を装備", game_path(battle_command: "weapon"), class: "btn btn-outline-info w-100" %>
                  <% end %>
                  <%= button_to "逃走", escape_path(battle_command: battle_command), method: :post, class: "btn btn-outline-light w-100" %>
                </div>

                <% if battle_command == "attack" %>
                  <% selected_attack_attribute = AttackAttribute.normalize(params[:attack_attribute].presence || equipped_weapon&.primary_attack_attribute || "斬撃") %>
                  <h5>攻撃種別</h5>
                  <div class="d-grid gap-2 mb-3">
                    <% AttackAttribute.normal_attack_options.each do |label, attribute| %>
                      <%= link_to label,
                          game_path(battle_command: "attack", target_enemy_id: selected_enemy&.id, attack_attribute: attribute),
                          class: selected_attack_attribute == attribute ? "btn btn-warning w-100" : "btn btn-outline-warning w-100" %>
                    <% end %>
                  </div>
                  <% if battle_enemies.many? %>
                    <h5>攻撃対象</h5>
                    <div class="d-grid gap-2">
                      <% battle_enemies.each do |enemy| %>
                        <%= link_to "#{enemy.position}. #{enemy.mob.name} Lv#{enemy.effective_level} HP #{enemy.enemy_hp}/#{enemy.effective_max_hp}",
                            game_path(battle_command: "attack", target_enemy_id: enemy.id, attack_attribute: selected_attack_attribute),
                            class: enemy == selected_enemy ? "btn btn-warning w-100" : "btn btn-outline-warning w-100" %>
                      <% end %>
                    </div>
                  <% end %>
                  <% if selected_enemy %>
                    <h5 class="<%= battle_enemies.many? ? 'mt-3' : '' %>"><%= selected_enemy.mob.name %>の攻撃部位</h5>
                    <div class="d-grid gap-2">
                      <% selected_parts.each do |part| %>
                        <% state = selected_part_states[part.id.to_s] || {} %>
                        <% part_label = state["broken"] ? "#{part.name}（破壊済み）" : part.name %>
                        <%= button_to part_label,
                            attack_path(target_enemy_id: selected_enemy.id, mob_part_id: part.id, attack_attribute: selected_attack_attribute),
                            method: :post,
                            class: "btn btn-outline-warning w-100" %>
                      <% end %>
                    </div>
                  <% end %>
                <% elsif battle_command == "sword_skill" %>
                  <% unless equipped_weapon %>
                    <p class="mb-0">武器を装備していないため、ソードスキルは使用できません。</p>
                  <% else %>
                  <% sword_skill = @player.skills.find_by(name: "片手剣") %>
                  <% sword_skill_level = (sword_skill&.proficiency || 0).to_i %>
                  <% sword_skill_definitions = SkillCatalog.sword_skills.select { |skill_definition| skill_definition.unlocked?(sword_skill_level) } %>
                  <% selected_skill = params[:selected_skill].presence %>
                  <% selected_skill = nil unless sword_skill_definitions.any? { |skill_definition| skill_definition.key == selected_skill } %>
                  <% selected_skill_definition = SkillCatalog.find(selected_skill || sword_skill_definitions.first&.key || "vertical") %>
                  <% selected_skill_definition = sword_skill_definitions.first unless sword_skill_definitions.include?(selected_skill_definition) %>
                  <% selected_skill ||= selected_skill_definition&.key %>
                  <% selected_skill_is_area = selected_skill_definition&.area? %>
                  <h5>ソードスキル</h5>
                  <div class="d-grid gap-2 mb-3">
                    <% sword_skill_definitions.each do |skill_definition| %>
                      <%= link_to skill_definition.name,
                          game_path(battle_command: "sword_skill", selected_skill: skill_definition.key),
                          class: skill_definition.key == selected_skill ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
                    <% end %>
                  </div>

                  <% if selected_skill.present? && selected_skill_is_area %>
                    <% group_start = params[:group_start].to_i %>
                    <% group_start = battle_enemies.first&.position.to_i if group_start <= 0 %>
                    <% selected_group = battle_enemies.select { |enemy| enemy.position >= group_start && enemy.position < group_start + 4 }.first(4) %>
                    <% if battle_enemies.many? %>
                      <h6>攻撃グループ</h6>
                      <div class="d-grid gap-2 mb-3">
                        <% battle_enemies.each_with_index do |enemy, index| %>
                          <% group = battle_enemies[index, 4] || [] %>
                          <% next if group.empty? %>
                          <% names = group.map { |group_enemy| "#{group_enemy.position}.#{group_enemy.mob.name}" }.join(" / ") %>
                          <%= link_to names,
                              game_path(battle_command: "sword_skill", selected_skill: selected_skill, group_start: enemy.position),
                              class: enemy.position == group_start ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
                        <% end %>
                      </div>
                    <% end %>

                    <% if selected_group.one? %>
                      <% area_enemy = selected_group.first %>
                      <% area_parts = BattleService.ensure_mob_parts!(area_enemy.mob) %>
                      <% area_part_states = (@part_states_by_enemy || {})[area_enemy.id] || {} %>
                      <h6><%= area_enemy.mob.name %>の攻撃部位</h6>
                      <div class="d-grid gap-2">
                        <% area_parts.each do |part| %>
                          <% state = area_part_states[part.id.to_s] || {} %>
                          <% part_label = state["broken"] ? "#{part.name}（破壊済み）" : part.name %>
                          <%= button_to part_label,
                              sword_skill_path(skill: selected_skill, group_start: group_start, target_enemy_id: area_enemy.id, mob_part_id: part.id),
                              method: :post,
                              class: "btn btn-outline-danger w-100" %>
                        <% end %>
                      </div>
                    <% elsif selected_group.any? %>
                      <%= button_to "#{selected_group.size}体へ発動",
                          sword_skill_path(skill: selected_skill, group_start: group_start),
                          method: :post,
                          class: "btn btn-danger w-100" %>
                      <p class="text-secondary small mt-2 mb-0">複数対象時は部位を選べず、命中しやすい部位へ自動で当たります。</p>
                    <% end %>
                  <% elsif selected_skill.present? %>
                    <% if battle_enemies.many? %>
                      <h6>攻撃対象</h6>
                      <div class="d-grid gap-2 mb-3">
                        <% battle_enemies.each do |enemy| %>
                          <%= link_to "#{enemy.position}. #{enemy.mob.name} Lv#{enemy.effective_level} HP #{enemy.enemy_hp}/#{enemy.effective_max_hp}",
                              game_path(battle_command: "sword_skill", selected_skill: selected_skill, target_enemy_id: enemy.id),
                              class: enemy == selected_enemy ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
                        <% end %>
                      </div>
                    <% end %>
                    <% if selected_enemy %>
                      <h6><%= selected_enemy.mob.name %>の攻撃部位</h6>
                      <div class="d-grid gap-2">
                        <% selected_parts.each do |part| %>
                          <% state = selected_part_states[part.id.to_s] || {} %>
                          <% part_label = state["broken"] ? "#{part.name}（破壊済み）" : part.name %>
                          <%= button_to part_label,
                              sword_skill_path(target_enemy_id: selected_enemy.id, mob_part_id: part.id, skill: selected_skill),
                              method: :post,
                              class: "btn btn-outline-danger w-100" %>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                  <% if selected_parts.empty? %>
                    <div class="btn btn-outline-secondary disabled w-100">攻撃可能部位なし</div>
                  <% end %>
                  <% end %>
                <% elsif battle_command == "weapon" %>
                  <% available_weapons = @player.weapons.where(equipped: false).to_a %>
                  <h5>武器を装備</h5>
                  <% if available_weapons.any? %>
                    <p>武器を装備しますか？ 装備変更には1ターン消費します。</p>
                    <div class="d-grid gap-2">
                      <% available_weapons.each do |weapon| %>
                        <div class="border rounded p-2">
                          <p class="mb-1"><%= weapon.display_name %></p>
                          <p class="mb-1">攻撃力: <%= weapon.attack_power %> / 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                          <% if weapon.effective_part_break_power > 100 %>
                            <p class="mb-1">特性: 部位破壊率が高い</p>
                          <% end %>
                          <p class="mb-2">補正: HP +<%= weapon.hp_bonus %> / 筋力 +<%= weapon.strength_bonus %> / 敏捷 +<%= weapon.agility_bonus %></p>
                          <%= button_to "装備する", equip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-info w-100" %>
                        </div>
                      <% end %>
                      <%= link_to "変更しない", game_path(battle_command: "attack"), class: "btn btn-outline-light w-100" %>
                    </div>
                  <% else %>
                    <p class="mb-0">装備できる武器がありません。通常攻撃または逃走を選択してください。</p>
                  <% end %>
                <% elsif battle_command == "item" %>
                  <h5>アイテム</h5>
                  <div class="d-grid gap-2">
                    <% potion = @player.items.find_by(name: "ポーション", category: "healing") || @player.items.find_by(name: "ポーション") %>
                    <% if potion&.quantity.to_i.positive? %>
                      <%= button_to "ポーション × #{potion.quantity}", use_battle_item_path(item_name: "ポーション"), method: :post, class: "btn btn-outline-success w-100" %>
                    <% else %>
                      <div class="btn btn-outline-secondary disabled w-100">使用可能なアイテムなし</div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="mb-0">コマンドを選択してください。</p>
                <% end %>
              <% else %>
              <% if selected_panel == "equipment" %>
                <h5>装備</h5>
                <% if equipped_weapons.any? %>
                  <% equipped_weapons.each do |weapon| %>
                    <div class="border rounded p-2 mb-2">
                      <p class="mb-1">武器: <%= weapon.display_name %></p>
                      <p class="mb-1">種別: <%= weapon.weapon_type %></p>
                      <p class="mb-1">攻撃力: <%= weapon.attack_power %></p>
                      <p class="mb-1">クリティカル率: <%= weapon.critical_rate %>%</p>
                      <p class="mb-1">耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                      <% if weapon.effective_part_break_power > 100 %>
                        <p class="mb-1">特性: 部位破壊率が高い</p>
                      <% end %>
                      <p class="mb-0">補正: HP +<%= weapon.hp_bonus %> / 筋力 +<%= weapon.strength_bonus %> / 敏捷 +<%= weapon.agility_bonus %></p>
                      <%= button_to "取り外す", unequip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
                    </div>
                  <% end %>
                  <p>武器枠: <%= equipped_weapons.count %> / <%= @player.dual_wield? ? 2 : 1 %></p>
                <% else %>
                  <p class="mb-0">装備中の武器なし</p>
                <% end %>

                <h5 class="mt-3">装備中の防具</h5>
                <p>装備重量: <%= @player.equipment_weight %> / 重量ペナルティ: <%= @player.equipment_weight_penalty %></p>
                <p>防御: <%= @player.damage_cut %></p>
                <% Armor::EQUIPPABLE_SLOTS.each do |slot| %>
                  <% armor = @player.armor_for(slot) %>
                  <p class="mb-1"><%= Armor.slot_name(slot) %>: <%= armor ? armor.name : "未装備" %></p>
                <% end %>
              <% elsif selected_panel == "items" %>
                <% item_category = params[:item_category].presence %>
                <h5>所持品</h5>
                <div class="d-grid gap-2 mb-3">
                  <%= link_to "所持武器", game_path(panel: "items", item_category: "weapons"), class: "btn btn-outline-light w-100" %>
                  <%= link_to "所持防具", game_path(panel: "items", item_category: "armors"), class: "btn btn-outline-light w-100" %>
                  <%= link_to "回復アイテム", game_path(panel: "items", item_category: "healing"), class: "btn btn-outline-light w-100" %>
                  <%= link_to "採取アイテム", game_path(panel: "items", item_category: "gathered"), class: "btn btn-outline-light w-100" %>
                  <%= link_to "ドロップアイテム", game_path(panel: "items", item_category: "drop"), class: "btn btn-outline-light w-100" %>
                </div>



              <% elsif selected_panel == "skills" %>
                <% selected_skill_set = params[:skill_set].presence %>
                <% selected_sword_skill = params[:sword_skill].presence %>
                <h5>スキル</h5>
                <p>スキルスロット: <%= @player.used_skill_slots %> / <%= @player.skill_slots.to_i %>（空き <%= @player.remaining_skill_slots %>）</p>
                <% @player.skills.each do |skill| %>
                  <%= link_to "#{skill.name}: #{skill.proficiency.to_i}/1000", game_path(panel: "skills", skill_set: skill.name), class: "btn btn-outline-light w-100 mb-2" %>
                  <div class="progress mb-3">
                    <div class="progress-bar" style="width: <%= skill.proficiency.to_i / 10 %>%"></div>
                  </div>
                <% end %>
                <% if selected_skill_set == "片手剣" %>
                  <% sword_skill = @player.skills.find_by(name: "片手剣") %>
                  <% sword_skill_level = (sword_skill&.proficiency || 0).to_i %>
                  <h5 class="mt-3">片手直剣ソードスキル</h5>
                  <% SkillCatalog.sword_skills.select { |skill_definition| skill_definition.unlocked?(sword_skill_level) }.each do |skill_definition| %>
                    <%= link_to "#{skill_definition.name} / 倍率#{skill_definition.damage_multiplier}%#{skill_definition.hits > 1 ? "×#{skill_definition.hits}" : ""} / #{skill_definition.target_label}",
                        game_path(panel: "skills", skill_set: "片手剣", sword_skill: skill_definition.key),
                        class: "btn btn-outline-light w-100 mb-2" %>
                  <% end %>

                  <% if selected_sword_skill.present? %>
                    <% detail_skill = SkillCatalog.find(selected_sword_skill) %>
                    <% if detail_skill&.unlocked?(sword_skill_level) %>
                      <div class="border rounded p-2 mt-3">
                        <p class="mb-1"><%= detail_skill.name %></p>
                        <p class="mb-1">必要熟練度: <%= detail_skill.required_proficiency %></p>
                        <p class="mb-1">攻撃倍率: <%= detail_skill.damage_multiplier %>%<%= detail_skill.hits > 1 ? " × #{detail_skill.hits}撃" : "" %></p>
                        <p class="mb-1">種別: <%= detail_skill.target_label %></p>
                        <p class="mb-0"><%= detail_skill.description %></p>
                      </div>
                    <% end %>
                  <% end %>
                <% end %>
              <% elsif selected_panel == "growth" %>
                <h5>成長</h5>
                <h6>装備込みステータス</h6>
                <p>レベル: <%= @player.level.to_i %></p>
                <p>HP: <%= @player.hp.to_i %> / <%= @player.effective_max_hp %>（基礎最大 <%= @player.max_hp.to_i %> / 筋力 +<%= @player.strength_hp_bonus %> / 武器 +<%= @player.weapon_hp_bonus %> / 防具 +<%= @player.armor_hp_bonus %>（<%= @player.armor_hp_bonus_percent %>%））</p>
                <p>筋力: <%= @player.effective_strength %>（基礎 <%= @player.strength.to_i %> / 武器 +<%= @player.weapon_strength_bonus %> / 防具 +<%= @player.armor_strength_bonus %>）</p>
                <p>敏捷: <%= @player.effective_agility %>（基礎 <%= @player.agility.to_i %> / 武器 +<%= @player.weapon_agility_bonus %> / 防具 +<%= @player.armor_agility_bonus %> / 重量 -<%= @player.equipment_weight_penalty %>）</p>
                <p>防御: <%= @player.damage_cut %></p>
                <p>装備重量: <%= @player.equipment_weight %></p>
                <p>経験値: <%= @player.exp.to_i %> / <%= @player.exp_to_next_level %></p>
                <p>スキルスロット: <%= @player.used_skill_slots %> / <%= @player.skill_slots.to_i %>（空き <%= @player.remaining_skill_slots %>）</p>
                <h6 class="mt-3">ポイント振り分け</h6>
                <p>振り分け: <%= @player.stat_points.to_i %> pt</p>
                <% if @player.stat_points.to_i > 0 %>
                  <% allocatable_points = [@player.stat_points.to_i, 3].min %>
                  <% strength_points = [[params[:strength_points].to_i, 0].max, allocatable_points].min %>
                  <% agility_points = [[params[:agility_points].to_i, 0].max, allocatable_points - strength_points].min %>
                  <% before_hp = @player.effective_max_hp %>
                  <% before_strength = @player.effective_strength %>
                  <% before_agility = @player.effective_agility %>
                  <% original_strength = @player.strength.to_i %>
                  <% original_agility = @player.agility.to_i %>
                  <% @player.strength = original_strength + strength_points %>
                  <% @player.agility = original_agility + agility_points %>
                  <% after_hp = @player.effective_max_hp %>
                  <% after_strength = @player.effective_strength %>
                  <% after_agility = @player.effective_agility %>
                  <% @player.strength = original_strength %>
                  <% @player.agility = original_agility %>
                  <div class="border border-warning rounded p-2 mb-2">
                    <p class="mb-1">最大<%= allocatable_points %>ポイントをまとめて振り分けます。</p>
                    <p class="mb-2">残り: <%= allocatable_points - strength_points - agility_points %> pt</p>
                    <div class="d-grid gap-2 mb-2">
                      <div class="d-flex align-items-center gap-2">
                        <span class="flex-fill">筋力 +<%= strength_points %></span>
                        <%= link_to "－", game_path(panel: "growth", strength_points: [strength_points - 1, 0].max, agility_points: agility_points), class: "btn btn-outline-light btn-sm" %>
                        <% next_strength = strength_points + agility_points < allocatable_points ? strength_points + 1 : strength_points %>
                        <%= link_to "＋", game_path(panel: "growth", strength_points: next_strength, agility_points: agility_points), class: "btn btn-outline-warning btn-sm" %>
                      </div>
                      <div class="d-flex align-items-center gap-2">
                        <span class="flex-fill">敏捷 +<%= agility_points %></span>
                        <%= link_to "－", game_path(panel: "growth", strength_points: strength_points, agility_points: [agility_points - 1, 0].max), class: "btn btn-outline-light btn-sm" %>
                        <% next_agility = strength_points + agility_points < allocatable_points ? agility_points + 1 : agility_points %>
                        <%= link_to "＋", game_path(panel: "growth", strength_points: strength_points, agility_points: next_agility), class: "btn btn-outline-warning btn-sm" %>
                      </div>
                    </div>
                    <%= form_with url: allocate_stats_path, method: :post, class: "d-grid gap-2" do %>
                      <%= hidden_field_tag :strength_points, strength_points %>
                      <%= hidden_field_tag :agility_points, agility_points %>
                      <p class="mb-1">最大HP: <%= before_hp %> → <%= after_hp %>（+<%= after_hp - before_hp %>）</p>
                      <p class="mb-1">筋力: <%= before_strength %> → <%= after_strength %></p>
                      <p class="mb-1">敏捷: <%= before_agility %> → <%= after_agility %></p>
                      <% unless @player.skip_stat_allocate_confirm? %>
                        <p class="mb-1 text-warning">本当に振り分けますか？ 振り直しはできません。</p>
                        <label class="small">
                          <%= check_box_tag :skip_confirm, "1", false %>
                          以降このメッセージを表示しない
                        </label>
                      <% end %>
                      <%= submit_tag "この配分で確定する", class: "btn btn-warning w-100", disabled: (strength_points + agility_points != allocatable_points) %>
                    <% end %>
                  </div>
                <% end %>
                <% learnable_skills = SkillUnlockService.available_for(@player) %>
                <% if learnable_skills.any? %>
                  <h6 class="mt-3">習得可能スキル</h6>
                  <div class="d-grid gap-2">
                    <% learnable_skills.each do |skill_definition| %>
                      <div class="border rounded p-2">
                        <p class="mb-2"><%= skill_definition.name %></p>
                        <%= button_to "習得する", learn_skill_path(skill_name: skill_definition.name), method: :post, class: "btn btn-outline-info w-100" %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% elsif selected_panel == "inn" %>
                <h5>宿屋</h5>

                <% unless @player.town_discovery_for&.found_inn? %>
                  <p class="mb-0">宿屋はまだ見つけていません。</p>
                <% else %>
                  <div class="d-grid gap-2">
                    <%= link_to "休憩", game_path(panel: "inn", inn_menu: "rest"), class: "btn btn-outline-success w-100" %>
                    <%= link_to "本拠点", game_path(panel: "inn", inn_menu: "base"), class: "btn btn-outline-info w-100" %>
                    <%= link_to "所持金管理", game_path(panel: "inn", inn_menu: "col"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "アイテム収納", game_path(panel: "inn", inn_menu: "storage"), class: "btn btn-outline-light w-100" %>
                    <%= link_to "施設から出る", game_path, class: "btn btn-outline-light w-100" %>
                  </div>
                <% end %>
              <% elsif selected_panel == "item_shop" %>
                <% shop_menu = params[:shop_menu].presence %>
                <h5>道具屋</h5>
                <% unless @player.town_discovery_for&.found_item_shop? %>
                  <p class="mb-0">道具屋はまだ見つけていません。</p>
                <% else %>
                  <div class="d-grid gap-2 mb-3">
                    <%= link_to "道具を購入", game_path(panel: "item_shop", shop_menu: "buy"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "道具を生産", game_path(panel: "item_shop", shop_menu: "produce"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "アイテムを売却", game_path(panel: "item_shop", shop_menu: "sell"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "施設から出る", game_path, class: "btn btn-outline-light w-100" %>
                  </div>
                <% end %>
              <% elsif selected_panel == "blacksmith" %>
                <% blacksmith_menu = params[:blacksmith_menu].presence %>
                <h5>鍛冶屋</h5>
                <% unless @player.town_discovery_for&.found_blacksmith? %>
                  <p class="mb-0">鍛冶屋はまだ見つけていません。</p>
                <% else %>
                  <div class="d-grid gap-2 mb-3">
                    <%= link_to "武器を購入する", game_path(panel: "blacksmith", blacksmith_menu: "buy"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "武器を整備する", game_path(panel: "blacksmith", blacksmith_menu: "repair"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "武器を強化する", game_path(panel: "blacksmith", blacksmith_menu: "upgrade"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "武器を進化する", game_path(panel: "blacksmith", blacksmith_menu: "evolve"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "武器を売却する", game_path(panel: "blacksmith", blacksmith_menu: "sell"), class: "btn btn-outline-warning w-100" %>
                    <%= link_to "施設から出る", game_path, class: "btn btn-outline-light w-100" %>
                  </div>
                <% end %>
              <% else %>
                <p class="mb-0">左のコマンドから情報を選択してください。</p>
              <% end %>
              <% end %>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <% if @battle.present? %>
            <div class="card bg-danger text-light mb-3">
              <div class="card-header">敵情報</div>
              <div class="card-body">
                <% battle_enemies = @battle_enemies.presence || @battle.alive_enemies.to_a %>
                <div class="d-flex flex-wrap gap-2">
                  <% battle_enemies.each do |enemy| %>
                    <div class="border rounded p-2 flex-fill" style="min-width: 140px;">
                      <h5 class="mb-2"><%= enemy.position %>. <%= enemy.mob.name %> Lv<%= enemy.effective_level %></h5>
                      <p class="mb-1">HP: <%= enemy.enemy_hp %> / <%= enemy.effective_max_hp %></p>
                      <div class="progress mb-0">
                        <div class="progress-bar bg-warning" style="width: <%= [[enemy.enemy_hp.to_i * 100 / [enemy.effective_max_hp, 1].max, 0].max, 100].min %>%"></div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>

          <% elsif @rest.present? %>
            <div class="card bg-info text-dark mb-3">
              <div class="card-header">休憩中</div>
              <div class="card-body">
                <p>安全を確保して休憩している。</p>

                <% if @player.skills.exists?(name: "昼寝") %>
                  <%= button_to "昼寝する", use_rest_skill_path, method: :post, class: "btn btn-success w-100 mb-2" %>
                <% end %>

                <%= button_to "ポーションを使う", use_rest_item_path, method: :post, class: "btn btn-outline-success w-100 mb-2" %>
                <%= button_to "休憩を終える", end_rest_path, method: :post, class: "btn btn-outline-dark w-100" %>
              </div>
            </div>

          <% else %>
            <% facility_panel_open = selected_panel.in?(%w[inn item_shop blacksmith equipment items]) && @player.location&.safe_area? %>
            <% if facility_panel_open %>
              <div class="card bg-secondary text-light mb-3">
                <% if selected_panel == "items" %>

                  <div class="card-header">所持品一覧</div>
                  <div class="card-body">

                    <% if params[:item_category] == "weapons" %>

                      <% @player.weapons.each do |weapon| %>
                        <div class="border rounded mb-2">
                          <button class="btn btn-dark w-100 text-start"
                                  type="button"
                                  data-bs-toggle="collapse"
                                  data-bs-target="#weapon-item-<%= weapon.id %>">

                            <%= weapon.display_name %>
                            <% if weapon.equipped? %>（装備中）<% end %>

                          </button>

                          <div class="collapse p-2"
                              id="weapon-item-<%= weapon.id %>">

                            <p>攻撃力: <%= weapon.attack_power %></p>
                            <p>耐久力: <%= weapon.durability %>/<%= weapon.max_durability %></p>

                            <% unless weapon.equipped? %>
                              <%= button_to "装備する",
                                  equip_weapon_path(weapon_id: weapon.id),
                                  method: :post,
                                  class: "btn btn-outline-warning w-100" %>
                            <% end %>
                          </div>
                        </div>
                      <% end %>

                    <% elsif params[:item_category] == "armors" %>

                      <% @player.armors.each do |armor| %>

                        <div class="border rounded mb-2">
                          <button class="btn btn-dark w-100 text-start"
                                  type="button"
                                  data-bs-toggle="collapse"
                                  data-bs-target="#armor-item-<%= armor.id %>">

                            <%= armor.name %>
                            <% if armor.equipped? %>（装備中）<% end %>

                          </button>

                          <div class="collapse p-2"
                              id="armor-item-<%= armor.id %>">

                            <p>防御力: <%= armor.defense %></p>
                            <p>重量: <%= armor.weight %></p>

                          </div>
                        </div>

                      <% end %>

                    <% elsif params[:item_category].in?(%w[healing gathered drop]) %>

                      <% items = @player.items.where(category: params[:item_category])
                                              .where("quantity > 0")
                                              .order(:name) %>

                      <% items.each do |item| %>

                        <div class="border rounded mb-2">

                          <button class="btn btn-dark w-100 text-start"
                                  type="button"
                                  data-bs-toggle="collapse"
                                  data-bs-target="#item-right-<%= item.id %>">

                            <%= item.name %> × <%= item.quantity %>

                          </button>

                          <div class="collapse p-2"
                              id="item-right-<%= item.id %>">

                            <% if item.category == "healing" %>
                              <%= button_to "使う",
                                  use_item_path(item_name: item.name),
                                  method: :post,
                                  class: "btn btn-outline-success w-100 mb-2" %>
                            <% end %>

                            <% if item.discardable_by_player? %>
                              <%= button_to "全部捨てる",
                                  discard_item_path(
                                    item_id: item.id,
                                    quantity: item.quantity
                                  ),
                                  method: :post,
                                  class: "btn btn-outline-danger w-100" %>
                            <% end %>

                          </div>

                        </div>

                      <% end %>

                    <% end %>

                  </div>

                <% elsif selected_panel == "equipment" %>
                  <div class="card-header">所持装備</div>
                  <div class="card-body">
                    <h6>所持武器</h6>

                    <% @player.weapons.each do |weapon| %>
                      <div class="border rounded mb-2">
                        <button class="btn btn-dark w-100 text-start"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#weapon-<%= weapon.id %>">
                          <%= weapon.display_name %>
                          <% if weapon.equipped? %>（装備中）<% end %>
                          <% if weapon.favorite? %> ★<% end %>
                        </button>

                        <div class="collapse p-2" id="weapon-<%= weapon.id %>">
                          <p class="mb-1">攻撃力: <%= weapon.attack_power %></p>
                          <p class="mb-1">耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                          <p class="mb-1">クリティカル率: <%= weapon.critical_rate %>%</p>

                          <% unless weapon.equipped? %>
                            <%= button_to "装備する", equip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-warning w-100 mt-2" %>
                          <% else %>
                            <%= button_to "取り外す", unequip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
                          <% end %>
                          <%= button_to weapon.favorite? ? "★ お気に入り解除" : "☆ お気に入り登録",
                              toggle_weapon_favorite_path(weapon_id: weapon.id),
                              method: :post,
                              class: "btn btn-outline-light w-100 mt-2" %>
                        </div>
                      </div>
                    <% end %>

                    <h6 class="mt-3">所持防具</h6>

                    <% @player.armors.each do |armor| %>
                      <div class="border rounded mb-2">
                        <button class="btn btn-dark w-100 text-start"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#armor-<%= armor.id %>">
                          <%= armor.name %>
                          <% if armor.equipped? %>（装備中）<% end %>
                          <% if armor.favorite? %> ★<% end %>
                        </button>

                        <div class="collapse p-2" id="armor-<%= armor.id %>">
                          <p class="mb-1">部位: <%= armor.slot_name %></p>
                          <p class="mb-1">防御: <%= armor.defense %></p>
                          <p class="mb-1">重量: <%= armor.weight %></p>

                          <% if armor.equipped? %>
                            <%= button_to "取り外す", unequip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
                          <% else %>
                            <%= button_to "装備する", equip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-info w-100 mt-2" %>
                          <% end %>
                          <%= button_to armor.favorite? ? "★ お気に入り解除" : "☆ お気に入り登録",
                              toggle_armor_favorite_path(armor_id: armor.id),
                              method: :post,
                              class: "btn btn-outline-light w-100 mt-2" %>
                        </div>
                      </div>
                    <% end %>
                  </div>

                <% elsif selected_panel == "inn" %>
                  <% inn_menu = params[:inn_menu].presence || "rest" %>
                  <% inn_cost = @player.location&.name == "ホルンカの村" ? 50 : 0 %>
                  <% current_base = @player.player_bases.find_by(location: @player.location, base_type: "home", active: true) %>

                  <div class="card-header">宿屋</div>
                  <div class="card-body">

                    <% if inn_menu == "rest" %>
                      <h6>休憩</h6>
                      <p>宿屋で休憩してHPを回復します。</p>
                      <%= button_to "休憩する（#{inn_cost}コル）", inn_path, method: :post, class: "btn btn-outline-success w-100" %>

                    <% elsif inn_menu == "base" %>
                      <h6>本拠点</h6>

                      <% if @player.home_base %>
                        <p>現在の本拠点: <%= @player.home_base.location.name %></p>
                      <% else %>
                        <p>本拠点は未設定です。</p>
                      <% end %>

                      <% if @player.home_base&.location_id != @player.location_id %>
                        <% if params[:confirm_home_base] == "1" %>
                          <div class="border border-info rounded p-2">
                            <p class="mb-2">ここを本拠点にしますか？</p>
                            <div class="d-flex gap-2">
                              <%= button_to "はい", set_home_base_path(confirm: "1"), method: :post, form: { class: "flex-fill" }, class: "btn btn-info w-100" %>
                              <%= link_to "いいえ", game_path(panel: "inn", inn_menu: "base"), class: "btn btn-outline-light flex-fill" %>
                            </div>
                          </div>
                        <% else %>
                          <%= link_to "この宿屋を本拠点にする", game_path(panel: "inn", inn_menu: "base", confirm_home_base: "1"), class: "btn btn-outline-info w-100" %>
                        <% end %>
                      <% else %>
                        <div class="text-info small text-center">現在の本拠点です</div>
                      <% end %>

                    <% elsif inn_menu == "col" %>
                      <h6>所持金管理</h6>

                      <% if current_base %>
                        <p>預け金: <%= @player.base_col.to_i %>コル</p>

                        <%= form_with url: deposit_base_col_path, method: :post, class: "d-grid gap-2 mb-3" do %>
                          <%= number_field_tag :amount, 100, min: 1, max: @player.col.to_i, class: "form-control form-control-sm" %>
                          <%= submit_tag "コルを預ける", class: "btn btn-outline-info w-100" %>
                        <% end %>

                        <%= form_with url: withdraw_base_col_path, method: :post, class: "d-grid gap-2" do %>
                          <%= number_field_tag :amount, 100, min: 1, max: @player.base_col.to_i, class: "form-control form-control-sm" %>
                          <%= submit_tag "コルを引き出す", class: "btn btn-outline-light w-100" %>
                        <% end %>
                      <% else %>
                        <p class="text-secondary small mb-0">この宿屋を本拠点にすると、所持金管理を使えます。</p>
                      <% end %>

                    <% elsif inn_menu == "storage" %>
                      <h6>アイテム収納</h6>

                      <% if current_base %>
                        <% storage_tab = params[:storage_tab].presence || "store" %>
                        <% item_category = params[:item_category].presence %>

                        <ul class="nav nav-tabs mb-2">
                          <li class="nav-item">
                            <%= link_to "預ける", game_path(panel: "inn", inn_menu: "storage", storage_tab: "store", item_category: item_category), class: "nav-link #{storage_tab == 'store' ? 'active' : ''}" %>
                          </li>
                          <li class="nav-item">
                            <%= link_to "取り出す", game_path(panel: "inn", inn_menu: "storage", storage_tab: "withdraw", item_category: item_category), class: "nav-link #{storage_tab == 'withdraw' ? 'active' : ''}" %>
                          </li>
                        </ul>

                    <div class="d-flex gap-2 mb-3 flex-wrap">
                    <%= link_to "全部",
                      game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab),
                      class: "btn btn-sm #{item_category.blank? ? 'btn-info' : 'btn-outline-light'}" %>
                      <%= link_to "回復", game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab, item_category: "healing"), class: "btn btn-sm #{item_category == 'healing' ? 'btn-info' : 'btn-outline-light'}" %>

                      <%= link_to "採取", game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab, item_category: "gathered"), class: "btn btn-sm #{item_category == 'gathered' ? 'btn-info' : 'btn-outline-light'}" %>

                      <%= link_to "ドロップ", game_path(panel: "inn", inn_menu: "storage", storage_tab: storage_tab, item_category: "drop"), class: "btn btn-sm #{item_category == 'drop' ? 'btn-info' : 'btn-outline-light'}" %>
                    </div>

                        <% if storage_tab == "store" %>
                          <% carried_items = @player.items.where("quantity > 0").order(:category, :name) %>
                          <% carried_items = carried_items.where(category: item_category) if item_category.present? %>

                          <% if carried_items.any? %>
                            <div class="d-grid gap-2">
                              <% carried_items.each do |item| %>
                                <div class="border rounded">
                                  <button class="btn btn-dark w-100 text-start"
                                          type="button"
                                          data-bs-toggle="collapse"
                                          data-bs-target="#store-item-<%= item.id %>">
                                    <%= item.name %> × <%= item.quantity %>
                                  </button>

                                  <div class="collapse p-2" id="store-item-<%= item.id %>">
                                    <%= form_with url: store_item_path(item_id: item.id), method: :post, class: "d-flex gap-2 mb-2" do %>
                                      <%= number_field_tag :quantity, item.quantity, min: 1, max: item.quantity, class: "form-control form-control-sm" %>
                                      <%= submit_tag "預ける", class: "btn btn-outline-light btn-sm" %>
                                    <% end %>

                                    <%= button_to "全部預ける",
                                                  store_item_path(item_id: item.id, quantity: item.quantity),
                                                  method: :post,
                                                  class: "btn btn-outline-info btn-sm w-100" %>
                                  </div>
                                </div>
                              <% end %>
                            </div>
                          <% else %>
                            <p class="text-secondary small mb-0">預けられるアイテムはありません。</p>
                          <% end %>

                        <% else %>
                          <% storage_items = current_base.storage_items.where("quantity > 0").order(:category, :name) %>
                          <% storage_items = storage_items.where(category: item_category) if item_category.present? %>

                          <% if storage_items.any? %>
                            <div class="d-grid gap-2">
                              <% storage_items.each do |storage_item| %>
                                <div class="border rounded">
                                  <button class="btn btn-dark w-100 text-start"
                                          type="button"
                                          data-bs-toggle="collapse"
                                          data-bs-target="#withdraw-item-<%= storage_item.id %>">
                                    <%= storage_item.name %> × <%= storage_item.quantity %>
                                  </button>

                                  <div class="collapse p-2" id="withdraw-item-<%= storage_item.id %>">
                                    <%= form_with url: withdraw_item_path(storage_item_id: storage_item.id), method: :post, class: "d-flex gap-2 mb-2" do %>
                                      <%= number_field_tag :quantity, storage_item.quantity, min: 1, max: storage_item.quantity, class: "form-control form-control-sm" %>
                                      <%= submit_tag "取り出す", class: "btn btn-outline-light btn-sm" %>
                                    <% end %>

                                    <%= button_to "全部取り出す",
                                                  withdraw_item_path(storage_item_id: storage_item.id, quantity: storage_item.quantity),
                                                  method: :post,
                                                  class: "btn btn-outline-info btn-sm w-100" %>
                                  </div>
                                </div>
                              <% end %>
                            </div>
                          <% else %>
                            <p class="text-secondary small mb-0">収納中のアイテムはありません。</p>
                          <% end %>
                        <% end %>

                      <% else %>
                        <p class="text-secondary small mb-0">
                          この宿屋を本拠点にすると、アイテム収納を使えます。
                        </p>
                      <% end %>
                    <% end %>
                  </div>
                <% elsif selected_panel == "item_shop" %>
                  <% shop_menu = params[:shop_menu].presence %>
                  <div class="card-header">道具屋</div>
                  <div class="card-body">
                    <% if shop_menu == "buy" %>
                      <% shop_items = ShopCatalog.item_shop_items(@player.location) %>
                      <% selected_shop_item = shop_items.find { |shop_item| shop_item.item_name == params[:item_name] } %>
                      <% if selected_shop_item %>
                        <h6><%= selected_shop_item.item_name %></h6>
                        <p class="mb-1">価格: <%= selected_shop_item.price %>コル</p>
                        <p class="mb-1">種別: <%= selected_shop_item.category %></p>
                        <p class="mb-1">重さ: <%= Item.new(name: selected_shop_item.item_name, category: selected_shop_item.category).weight %></p>
                        <% if selected_shop_item.item_name == "ポーション" %>
                          <p class="mb-2">効果: HPを100回復</p>
                        <% else %>
                          <p class="mb-2">効果: 使用効果なし</p>
                        <% end %>
                        <%= button_to "購入する", item_shop_path(item_name: selected_shop_item.item_name), method: :post, class: "btn btn-warning w-100" %>
                      <% elsif shop_items.any? %>
                        <div class="d-grid gap-2">
                          <% shop_items.each do |shop_item| %>
                            <%= link_to "#{shop_item.item_name} / #{shop_item.price}コル / #{shop_item.category}",
                                game_path(panel: "item_shop", shop_menu: "buy", item_name: shop_item.item_name),
                                class: "btn btn-outline-warning w-100" %>
                          <% end %>
                        </div>
                      <% else %>
                        <p class="mb-0">この町の道具屋には販売品がありません。</p>
                      <% end %>
                    <% elsif shop_menu == "produce" %>
                      <% herb = @player.items.find_by(name: "薬草", category: "gathered") || @player.items.find_by(name: "薬草") %>
                      <h6>ポーション</h6>
                      <p class="mb-1">必要素材: 薬草 10個</p>
                      <p class="mb-1">費用: 20コル</p>
                      <p class="mb-2">所持薬草: <%= (herb&.quantity || 0).to_i %></p>
                      <%= button_to "ポーションを生産する", produce_item_path, method: :post, class: "btn btn-outline-warning w-100" %>
                    <% elsif shop_menu == "sell" %>
                      <% sellable_items = @player.items.select { |item| item.quantity.to_i.positive? && (item.sellable_by_player? || item.unique_item?) } %>
                      <% if sellable_items.any? %>
                        <div class="d-grid gap-2">
                          <% sellable_items.each do |item| %>
                            <div class="border rounded p-2">
                              <p class="mb-1"><%= item.name %> × <%= item.quantity %></p>
                              <p class="mb-2">売却価格: <%= item.sell_price %>コル</p>
                              <% if item.unique_item? && params[:confirm_item_id].to_i != item.id %>
                                <%= link_to "売却確認へ", game_path(panel: "item_shop", shop_menu: "sell", confirm_item_id: item.id), class: "btn btn-outline-danger w-100" %>
                              <% else %>
                                <% if item.unique_item? %>
                                  <p class="text-danger small mb-2">このアイテムは二度と手に入らないかもしれません。本当に売却しますか？</p>
                                <% end %>
                                <%= button_to "1つ売却する", sell_item_path(item_name: item.name, confirm_unique: item.unique_item? ? "1" : nil), method: :post, class: "btn btn-outline-warning w-100" %>
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                      <% else %>
                        <p class="mb-0">売却できるアイテムがありません。</p>
                      <% end %>
                    <% else %>
                      <p class="mb-0">左のメニューから行動を選択してください。</p>
                    <% end %>
                  </div>
                <% elsif selected_panel == "blacksmith" %>
                  <% blacksmith_menu = params[:blacksmith_menu].presence %>
                  <div class="card-header">鍛冶屋</div>
                  <div class="card-body">
                  <% if blacksmith_menu == "buy" %>
                    <% shop_weapons = ShopCatalog.blacksmith_weapons(@player.location) %>
                    <% selected_shop_weapon = shop_weapons.find { |weapon| weapon.name == params[:weapon_name] } %>
                    <% if selected_shop_weapon %>
                      <h6><%= selected_shop_weapon.name %></h6>
                      <p class="mb-1">価格: <%= selected_shop_weapon.price %>コル</p>
                      <p class="mb-1">武器種: <%= selected_shop_weapon.weapon_type %></p>
                      <p class="mb-1">攻撃力: <%= selected_shop_weapon.attack_power %></p>
                      <p class="mb-1">攻撃属性: <%= selected_shop_weapon.attack_attributes %></p>
                      <p class="mb-1">耐久力: <%= selected_shop_weapon.durability %> / <%= selected_shop_weapon.max_durability %></p>
                      <p class="mb-1">重さ: <%= selected_shop_weapon.weight %></p>
                      <p class="mb-1">参照ステータス: 筋力<%= selected_shop_weapon.strength_ratio %>% / 敏捷<%= selected_shop_weapon.agility_ratio %>%</p>
                      <p class="mb-1">補正: HP +<%= selected_shop_weapon.hp_bonus %> / 筋力 +<%= selected_shop_weapon.strength_bonus %> / 敏捷 +<%= selected_shop_weapon.agility_bonus %></p>
                      <% if selected_shop_weapon.description.present? %>
                        <p class="mb-2"><%= selected_shop_weapon.description %></p>
                      <% end %>
                      <%= button_to "購入する", buy_bronze_sword_path(weapon_name: selected_shop_weapon.name), method: :post, class: "btn btn-warning w-100" %>
                    <% elsif shop_weapons.any? %>
                      <div class="d-grid gap-2">
                        <% shop_weapons.each do |weapon| %>
                          <%= link_to "#{weapon.name} / #{weapon.price}コル / #{weapon.weapon_type}", game_path(panel: "blacksmith", blacksmith_menu: "buy", weapon_name: weapon.name), class: "btn btn-outline-warning w-100" %>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="mb-0">この町の鍛冶屋には販売武器がありません。</p>
                    <% end %>
                  <% elsif blacksmith_menu == "repair" %>
                    <% if equipped_weapon %>
                      <p class="mb-1">対象: <%= equipped_weapon.display_name %></p>
                      <p class="mb-1">耐久力: <%= equipped_weapon.durability %> / <%= equipped_weapon.max_durability %></p>
                      <p class="mb-2">費用: <%= equipped_weapon.repair_cost %>コル</p>
                      <%= button_to "整備する", blacksmith_path, method: :post, class: "btn btn-outline-warning w-100" %>
                    <% else %>
                      <p class="mb-0">整備できる装備中の武器がありません。</p>
                    <% end %>
                  <% elsif blacksmith_menu == "upgrade" %>
                    <% selected_weapon = @player.weapons.find_by(id: params[:weapon_id]) %>
                    <% if selected_weapon %>
                      <% upgrade_recipe = WeaponUpgradeService.recipe_for(selected_weapon) %>
                      <h6><%= selected_weapon.display_name %></h6>
                      <p class="mb-1">現在攻撃力: <%= selected_weapon.effective_attack_power %></p>
                      <p class="mb-1">強化後: +<%= selected_weapon.enhancement_level.to_i + 1 %></p>
                      <p class="mb-1">必要素材: <%= upgrade_recipe&.required_materials&.map { |name, count| "#{name} ×#{count}" }&.join("、") || "硬い甲殻 ×1" %></p>
                      <p class="mb-2">必要コル: <%= upgrade_recipe&.required_col.to_i %></p>
                      <%= button_to "強化する", upgrade_weapon_path(weapon_id: selected_weapon.id), method: :post, class: "btn btn-outline-warning w-100" %>
                    <% elsif @player.weapons.any? %>
                      <div class="d-grid gap-2">
                        <% @player.weapons.each do |weapon| %>
                          <%= link_to "#{weapon.display_name} / 攻撃力 #{weapon.effective_attack_power}", game_path(panel: "blacksmith", blacksmith_menu: "upgrade", weapon_id: weapon.id), class: "btn btn-outline-warning w-100" %>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="mb-0">強化できる武器がありません。</p>
                    <% end %>
                  <% elsif blacksmith_menu == "evolve" %>
                    <% selected_weapon = @player.weapons.find_by(id: params[:weapon_id]) %>
                    <% rule = WeaponEvolutionRule.find_by(source_weapon_name: selected_weapon&.name) %>
                    <% if selected_weapon && rule %>
                      <h6><%= selected_weapon.display_name %></h6>
                      <p class="mb-1">進化先: <%= rule.target_weapon_name %></p>
                      <p class="mb-1">必要強化値: +<%= rule.required_enhancement_level %></p>
                      <p class="mb-2">必要Lv: <%= rule.required_player_level %></p>
                      <%= button_to "進化する", evolve_weapon_path(weapon_id: selected_weapon.id), method: :post, class: "btn btn-outline-warning w-100" %>
                    <% else %>
                      <div class="d-grid gap-2">
                        <% @player.weapons.each do |weapon| %>
                          <% next unless WeaponEvolutionRule.exists?(source_weapon_name: weapon.name) %>
                          <%= link_to weapon.display_name, game_path(panel: "blacksmith", blacksmith_menu: "evolve", weapon_id: weapon.id), class: "btn btn-outline-warning w-100" %>
                        <% end %>
                      </div>
                    <% end %>
                  <% elsif blacksmith_menu == "sell" %>
                    <% sellable_weapons = @player.weapons.select(&:sellable_by_player?) %>
                    <% if sellable_weapons.any? %>
                      <div class="d-grid gap-2">
                        <% sellable_weapons.each do |weapon| %>
                          <div class="border rounded p-2">
                            <p class="mb-1"><%= weapon.display_name %></p>
                            <p class="mb-1">攻撃力: <%= weapon.effective_attack_power %> / 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                            <p class="mb-2">売却額: <%= weapon.sell_price %>コル</p>
                            <% if weapon.unique_item? && params[:confirm_weapon_id].to_i != weapon.id %>
                              <%= link_to "売却確認へ", game_path(panel: "blacksmith", blacksmith_menu: "sell", confirm_weapon_id: weapon.id), class: "btn btn-outline-danger w-100" %>
                            <% else %>
                              <% if weapon.unique_item? %>
                                <p class="text-danger small mb-2">この武器は二度と手に入らないかもしれません。本当に売却しますか？</p>
                              <% end %>
                              <%= button_to "売却する", sell_weapon_path(weapon_id: weapon.id, confirm_unique: weapon.unique_item? ? "1" : nil), method: :post, class: "btn btn-outline-warning w-100" %>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="mb-0">売却できる武器がありません。</p>
                    <% end %>
                  <% else %>
                    <p class="mb-0">左のメニューから行動を選択してください。</p>
                  <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
            <div class="d-grid gap-2">
              <% if @player.field_route.present? %>
                <% route = @player.field_route %>
                <div class="d-flex gap-2">
                  <%= button_to "探索", explore_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-primary btn-lg w-100" %>
                  <%= button_to "狩り", hunt_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-danger btn-lg w-100" %>
                  <%= button_to "採取", gather_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-success btn-lg w-100" %>
                  <%= button_to "休憩", start_rest_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-light btn-lg w-100" %>
                </div>

              <% elsif @player.location&.safe_area? %>
                <%= button_to "街を散策する", stroll_path, method: :post, class: "btn btn-primary btn-lg" %>

                <h5 class="mt-3">施設</h5>

                <% town_discovery = @town_discovery || @player.town_discovery_for %>
                <% if town_discovery&.found_inn? %>
                  <%= link_to "宿屋に入る", game_path(panel: "inn"), class: "btn btn-outline-success w-100" %>
                <% end %>

                <% if town_discovery&.found_item_shop? %>
                  <%= link_to "道具屋に入る", game_path(panel: "item_shop"), class: "btn btn-outline-warning w-100" %>
                <% end %>

                <% if town_discovery&.found_blacksmith? %>
                  <%= link_to "鍛冶屋に入る", game_path(panel: "blacksmith"), class: "btn btn-outline-warning w-100" %>
                <% end %>
              <% else %>
                <div class="d-flex gap-2">
                  <%= button_to "探索", explore_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-primary btn-lg w-100" %>
                  <%= button_to "狩り", hunt_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-danger btn-lg w-100" %>
                  <%= button_to "採取", gather_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-success btn-lg w-100" %>
                  <%= button_to "休憩", start_rest_path, method: :post, form: { class: "flex-fill" }, class: "btn btn-outline-light btn-lg w-100" %>
                </div>
                <% if @available_treasures.present? %>
                  <h5 class="mt-3">発見済み宝箱</h5>
                  <div class="d-grid gap-2">
                    <% @available_treasures.each do |treasure| %>
                      <%= button_to "#{treasure.name}を開ける",
                          open_treasure_path(treasure_chest_id: treasure.id),
                          method: :post,
                          class: "btn btn-outline-warning w-100" %>
                    <% end %>
                  </div>
                <% end %>
                <% if @available_bosses.present? %>
                  <h5 class="mt-3">発見済みボス</h5>
                  <div class="d-grid gap-2">
                    <% @available_bosses.each do |boss| %>
                      <%= button_to "#{boss.name}に挑む",
                          challenge_boss_path(mob_id: boss.id),
                          method: :post,
                          class: boss.boss_type == "field_boss" ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
                    <% end %>
                  </div>
                <% end %>
              <% end %>

              <h5 class="mt-3">移動</h5>

              <% if @player.field_route.present? %>
                <% route = @player.field_route %>
                <% route_progress = @player.player_route_progresses.find_by(route: route) %>
                <% destination_discovered = FieldService.destination_discovered?(@player, route) %>
                <% destination_reached = route_progress&.reached_destination? %>
                <% next_discovered_area = FieldService.next_discovered_area_for(@player, route) %>

                <div class="mb-2">
                  <%= button_to "#{route.from_location.name}方面へ戻る",
                      move_path(route_id: route.id, direction: "backward"),
                      method: :post,
                      class: "btn btn-outline-warning w-100 mb-1" %>

                  <% if destination_discovered %>
                    <%= button_to "#{route.to_location.name}方面へ進む",
                        move_path(route_id: route.id, direction: "forward"),
                        method: :post,
                        class: "btn btn-outline-info w-100 mb-2" %>
                  <% elsif next_discovered_area %>
                    <%= button_to "探索済みのエリア（#{next_discovered_area.name}）まで進む",
                        move_path(route_id: route.id, direction: "area"),
                        method: :post,
                        class: "btn btn-outline-info w-100 mb-2" %>
                  <% end %>

                  <% unless destination_discovered %>
                    <div class="small text-secondary mb-2">周辺を探索して道筋を探そう</div>
                  <% end %>
                </div>

              <% else %>
                <% @routes.each do |route| %>
                  <%= button_to "#{route.name}へ出る",
                      move_path(route_id: route.id),
                      method: :post,
                      class: "btn btn-outline-info w-100 mb-2" %>
                <% end %>
              <% end %>
            </div>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="border-top border-secondary mt-4 pt-3 d-flex justify-content-between align-items-center">
        <span class="text-secondary">ログイン中: <%= current_user.username %></span>
        <%= button_to "ログアウト", logout_path, method: :delete, class: "btn btn-outline-light" %>
      </div>
    </div>
  </div>
</div>

