                <% if @player.skills.exists?(name: "昼寝") %>
                  <%= button_to "昼寝する", use_rest_skill_path, method: :post, class: "btn btn-success w-100 mb-2" %>
                <% end %>

                <%= button_to "ポーションを使う", use_rest_item_path, method: :post, class: "btn btn-outline-success w-100 mb-2" %>
                <%= button_to "休憩を終える", end_rest_path, method: :post, class: "btn btn-outline-dark w-100" %>
              </div>
            </div>

          <% else %>
            <% facility_panel_open = selected_panel.in?(%w[inn item_shop blacksmith]) && @player.location&.safe_area? %>
            <% if facility_panel_open %>
              <div class="card bg-secondary text-light mb-3">
                <% if selected_panel == "inn" %>
                  <% inn_cost = @player.location&.name == "ホルンカの村" ? 50 : 0 %>
                  <div class="card-header">宿屋でできること</div>
                  <div class="card-body d-grid gap-2">
                    <%= button_to "休憩する（#{inn_cost}コル）", inn_path, method: :post, class: "btn btn-outline-success w-100" %>
                  </div>
                <% elsif selected_panel == "item_shop" %>
                  <% shop_menu = params[:shop_menu].presence %>
