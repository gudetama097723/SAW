                  <h5 class="mt-3">片手直剣ソードスキル</h5>
                  <% SkillCatalog.sword_skills.select { |skill_definition| skill_definition.unlocked?(sword_skill_level) }.each do |skill_definition| %>
                    <%= link_to "#{skill_definition.name} / 倍率#{skill_definition.damage_multiplier}%#{skill_definition.hits > 1 ? "×#{skill_definition.hits}" : ""} / #{skill_definition.target_label}",
                        game_path(panel: "skills", skill_set: "片手剣", sword_skill: skill_definition.key),
                        class: "btn btn-outline-light w-100 mb-2" %>
                  <% end %>

                  <% if selected_sword_skill.present? %>
                    <% detail_skill = SkillCatalog.find(selected_sword_skill) %>
                    <% if detail_skill&.unlocked?(sword_skill_level) %>
                      <div class="border rounded p-2 mt-3">
                        <p class="mb-1"><%= detail_skill.name %></p>
                        <p class="mb-1">必要熟練度: <%= detail_skill.required_proficiency %></p>
                        <p class="mb-1">攻撃倍率: <%= detail_skill.damage_multiplier %>%<%= detail_skill.hits > 1 ? " × #{detail_skill.hits}撃" : "" %></p>
                        <p class="mb-1">種別: <%= detail_skill.target_label %></p>
                        <p class="mb-0"><%= detail_skill.description %></p>
                      </div>
                    <% end %>
                  <% end %>
                <% end %>
              <% elsif selected_panel == "growth" %>
                <h5>成長</h5>
                <h6>装備込みステータス</h6>
                <p>レベル: <%= @player.level.to_i %></p>
                <p>HP: <%= @player.hp.to_i %> / <%= @player.effective_max_hp %>（基礎最大 <%= @player.max_hp.to_i %> / 筋力 +<%= @player.strength_hp_bonus %> / 武器 +<%= @player.weapon_hp_bonus %> / 防具 +<%= @player.armor_hp_bonus %>（<%= @player.armor_hp_bonus_percent %>%））</p>
                <p>筋力: <%= @player.effective_strength %>（基礎 <%= @player.strength.to_i %> / 武器 +<%= @player.weapon_strength_bonus %> / 防具 +<%= @player.armor_strength_bonus %>）</p>
                <p>敏捷: <%= @player.effective_agility %>（基礎 <%= @player.agility.to_i %> / 武器 +<%= @player.weapon_agility_bonus %> / 防具 +<%= @player.armor_agility_bonus %> / 重量 -<%= @player.equipment_weight_penalty %>）</p>
                <p>防御: <%= @player.damage_cut %></p>
                <p>装備重量: <%= @player.equipment_weight %></p>
                <p>経験値: <%= @player.exp.to_i %> / <%= @player.exp_to_next_level %></p>
                <p>スキルスロット: <%= @player.used_skill_slots %> / <%= @player.skill_slots.to_i %>（空き <%= @player.remaining_skill_slots %>）</p>
                <h6 class="mt-3">ポイント振り分け</h6>
                <p>振り分け: <%= @player.stat_points.to_i %> pt</p>
                <% if @player.stat_points.to_i > 0 %>
                  <% allocatable_points = [@player.stat_points.to_i, 3].min %>
                  <% strength_points = [[params[:strength_points].to_i, 0].max, allocatable_points].min %>
                  <% agility_points = [[params[:agility_points].to_i, 0].max, allocatable_points - strength_points].min %>
                  <% before_hp = @player.effective_max_hp %>
                  <% before_strength = @player.effective_strength %>
                  <% before_agility = @player.effective_agility %>
                  <% original_strength = @player.strength.to_i %>
                  <% original_agility = @player.agility.to_i %>
                  <% @player.strength = original_strength + strength_points %>
                  <% @player.agility = original_agility + agility_points %>
                  <% after_hp = @player.effective_max_hp %>
                  <% after_strength = @player.effective_strength %>
                  <% after_agility = @player.effective_agility %>
                  <% @player.strength = original_strength %>
                  <% @player.agility = original_agility %>
                  <div class="border border-warning rounded p-2 mb-2">
                    <p class="mb-1">最大<%= allocatable_points %>ポイントをまとめて振り分けます。</p>
                    <%= form_with url: allocate_stats_path, method: :post, class: "d-grid gap-2" do %>
                      <label class="small">筋力
                        <%= number_field_tag :strength_points, strength_points, min: 0, max: allocatable_points, class: "form-control form-control-sm" %>
                      </label>
                      <label class="small">敏捷
                        <%= number_field_tag :agility_points, agility_points, min: 0, max: allocatable_points, class: "form-control form-control-sm" %>
                      </label>
                      <p class="mb-1">最大HP: <%= before_hp %> → <%= after_hp %>（+<%= after_hp - before_hp %>）</p>
                      <p class="mb-1">筋力: <%= before_strength %> → <%= after_strength %></p>
                      <p class="mb-1">敏捷: <%= before_agility %> → <%= after_agility %></p>
                      <% unless @player.skip_stat_allocate_confirm? %>
                        <p class="mb-1 text-warning">本当に振り分けますか？ 振り直しはできません。</p>
                        <label class="small">
                          <%= check_box_tag :skip_confirm, "1", false %>
                          以降このメッセージを表示しない
                        </label>
                      <% end %>
                      <%= submit_tag "この配分で確定する", class: "btn btn-warning w-100" %>
                    <% end %>
                  </div>
  <% end %>
  <% learnable_skills = SkillUnlockService.available_for(@player) %>
  <% if learnable_skills.any? %>
    <h6 class="mt-3">???????</h6>
    <div class="d-grid gap-2">
      <% learnable_skills.each do |skill_definition| %>
        <div class="border rounded p-2">
          <p class="mb-2"><%= skill_definition.name %></p>
          <%= button_to "????", learn_skill_path(skill_name: skill_definition.name), method: :post, class: "btn btn-outline-info w-100" %>
        </div>
      <% end %>
    </div>
  <% end %>
<% elsif selected_panel == "inn" %>

                <h5>宿屋</h5>
