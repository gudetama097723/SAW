                              <p class="mb-1">価格: <%= weapon.price %>コル</p>
                              <p class="mb-1">種別: <%= weapon.weapon_type %></p>
                              <p class="mb-1">攻撃力: <%= weapon.attack_power %></p>
                              <p class="mb-1">クリティカル率: <%= weapon.critical_rate %>%</p>
                              <p class="mb-1">耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                              <p class="mb-2">補正: HP +<%= weapon.hp_bonus %> / 筋力 +<%= weapon.strength_bonus %> / 敏捷 +<%= weapon.agility_bonus %></p>
                              <p><%= weapon.name %>を購入しますか？</p>
                              <%= button_to "はい", buy_bronze_sword_path(weapon_name: weapon.name), method: :post, class: "btn btn-warning w-100" %>
                            </div>
                          <% end %>
                        </div>
                      <% else %>
                        <p class="mb-0">この町の鍛冶屋には販売品がありません。</p>
                      <% end %>
                    <% elsif blacksmith_menu == "repair" %>
                      <% if equipped_weapon %>
