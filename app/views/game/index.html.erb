                      move_path(route_id: route.id),
                      method: :post,
                      class: "btn btn-outline-info w-100 mb-2" %>
                <% end %>
              <% end %>
            </div>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="border-top border-secondary mt-4 pt-3 d-flex justify-content-between align-items-center">
        <span class="text-secondary">ログイン中: <%= current_user.username %></span>
        <%= button_to "ログアウト", logout_path, method: :delete, class: "btn btn-outline-light" %>
      </div>
    </div>
  </div>
</div>

