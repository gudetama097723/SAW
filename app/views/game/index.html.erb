                              <% end %>
                              <%= button_to "購入する", item_shop_path(item_name: shop_item.item_name), method: :post, class: "btn btn-outline-warning w-100" %>
                            </div>
                          <% end %>
                        </div>
                      <% else %>
                        <p class="mb-0">この町の道具屋には販売品がありません。</p>
                      <% end %>
                    <% elsif shop_menu == "produce" %>
