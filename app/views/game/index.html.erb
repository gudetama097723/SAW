<div class="container py-4">
  <div class="card bg-dark text-light border-secondary shadow-lg">
    <%= render "header" %>

    <div class="card-body">
      <%= render "messages" %>

      <% selected_panel = params[:panel].presence %>
      <% equipped_weapon = @player.equipped_weapon %>
      <% equipped_weapons = @player.equipped_weapons %>
      <% current_time = @player.current_time.to_i %>

      <div class="row">
        <%= render "left_column", selected_panel: selected_panel, equipped_weapons: equipped_weapons %>
        <%= render "center_column", selected_panel: selected_panel, equipped_weapon: equipped_weapon, equipped_weapons: equipped_weapons %>
        <%= render "right_column", selected_panel: selected_panel, equipped_weapon: equipped_weapon %>
      </div>

      <%= render "footer" %>
    </div>
  </div>
</div>
