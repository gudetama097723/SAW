<div class="container py-4">
  <div class="card bg-dark text-light border-secondary shadow-lg">
    <div class="card-header text-center">
      <h1 class="mb-0">Sword Art World</h1>
      <div class="d-flex align-items-start gap-4">
        <div><h2>第1層</h2></div>
        <div>
          <div>フィールド名: <%= @player.field_route ? "#{@player.field_route.name}（移動中）" : (@player.location&.name || "不明") %></div>
          <% if @current_field_area %>
            <div class="small text-light">全体踏破度 <%= @player.field_route_mapping_progress %>%</div>
          <% end %>
        </div>
        <% if @player.field_route.present? %>
          <div>
            <div>現在地: <%= @current_field_area&.name || "不明" %></div>
            <div class="small text-light">
              エリア踏破度 <%= @current_field_area_progress&.mapping_progress.to_i %>%
            </div>
          </div>
        <% end %>

        <div class="ms-auto">ゲーム内時刻: <%= format("%02d:%02d", @player.current_time / 60, @player.current_time % 60) %></div>

      </div>
    </div>

    <div class="card-body">
      <div class="message-window mb-3 p-0 text-start overflow-auto" style="min-height: 6rem; max-height: 10rem;">
        <% message_text = alert.presence || notice.presence %>
        <% message_class = alert.present? ? "text-warning" : "text-success" %>
        <div class="message-line <%= message_text.present? ? "" : "text-secondary" %>" style="line-height: 1.35;">
          <% if message_text.present? %>
            <% message_text.to_s.split(/(\[enemy\].*?\[\/enemy\]|\[mapping\].*?\[\/mapping\])/m).each do |segment| %><% if segment.start_with?("[enemy]") %><span class="text-danger"><%= segment.delete_prefix("[enemy]").delete_suffix("[/enemy]") %></span><% elsif segment.start_with?("[mapping]") %><span class="text-info"><%= segment.delete_prefix("[mapping]").delete_suffix("[/mapping]") %></span><% else %><span class="<%= message_class %>"><%= segment %></span><% end %><% end %>
          <% else %>
            メッセージはありません。
          <% end %>
        </div>
      </div>

      <% selected_panel = params[:panel].presence %>
      <% equipped_weapon = @player.equipped_weapon %>
      <% equipped_weapons = @player.equipped_weapons %>
      <% current_time = @player.current_time.to_i %>

      <div class="row">
        <div class="col-md-4">
          <div class="card bg-secondary text-light mb-3">
            <div class="card-header">ステータス</div>
            <div class="card-body">
              <p>名前: <%= @player.name %></p>
              <p>Lv: <%= @player.level.to_i %></p>
              <p>HP: <%= @player.hp %> / <%= @player.effective_max_hp %></p>
              <div class="progress mb-2">
                <div class="progress-bar bg-success" style="width: <%= [[@player.hp.to_i * 100 / [@player.effective_max_hp, 1].max, 0].max, 100].min %>%"></div>
              </div>
              <p>経験値: <%= @player.exp.to_i %> / <%= @player.exp_to_next_level %></p>
              <div class="progress mb-2" style="height: 6px;">
                <div class="progress-bar bg-info" style="width: <%= [[@player.exp.to_i * 100 / [@player.exp_to_next_level, 1].max, 0].max, 100].min %>%"></div>
              </div>
              <% if equipped_weapons.any? %>
                <% equipped_weapons.each do |weapon| %>
                  <p class="mb-1"><%= weapon.name %> 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                <% end %>
              <% end %>
              <p>スキルスロット: <%= @player.used_skill_slots %> / <%= @player.skill_slots.to_i %></p>
              <p>コル: <%= @player.col %></p>
            </div>
          </div>

          <div class="card bg-secondary text-light mb-3">
            <div class="card-header">情報コマンド</div>
            <div class="card-body d-grid gap-2">
              <%= link_to "装備を見る", game_path(panel: "equipment"), class: "btn btn-outline-light w-100" %>
              <%= link_to "所持品を見る", game_path(panel: "items"), class: "btn btn-outline-light w-100" %>
              <%= link_to "スキルを見る", game_path(panel: "skills"), class: "btn btn-outline-light w-100" %>
              <%= link_to "成長を見る", game_path(panel: "growth"), class: @player.stat_points.to_i.positive? ? "btn btn-warning w-100" : "btn btn-outline-light w-100" %>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card bg-secondary text-light mb-3">
            <div class="card-header"><%= @battle.present? ? "戦闘コマンド" : "情報" %></div>
            <div class="card-body">
                <% if @battle.present? %>
                  <% battle_command = params[:battle_command].presence %>
                  <% battle_enemies = @battle_enemies.presence || @battle.alive_enemies.to_a %>
                  <% selected_enemy = battle_enemies.find { |enemy| enemy.id == params[:target_enemy_id].to_i } || battle_enemies.first %>
                  <% selected_parts = selected_enemy ? BattleService.ensure_mob_parts!(selected_enemy.mob) : [] %>
                  <% selected_part_states = selected_enemy ? (@part_states_by_enemy || {})[selected_enemy.id] || {} : {} %>

                <div class="d-grid gap-2 mb-3">
                  <%= link_to "通常攻撃", game_path(battle_command: "attack"), class: "btn btn-outline-warning w-100" %>
                  <% if equipped_weapon %>
                    <%= link_to "ソードスキル", game_path(battle_command: "sword_skill"), class: "btn btn-outline-danger w-100" %>
                  <% else %>
                    <div class="btn btn-outline-secondary disabled w-100">ソードスキル（武器なし）</div>
                  <% end %>
                  <%= link_to "アイテム", game_path(battle_command: "item"), class: "btn btn-outline-success w-100" %>
                  <% if !equipped_weapon && @player.weapons.where(equipped: false).any? %>
                    <%= link_to "武器を装備", game_path(battle_command: "weapon"), class: "btn btn-outline-info w-100" %>
                  <% end %>
                  <%= button_to "逃走", escape_path(battle_command: battle_command), method: :post, class: "btn btn-outline-light w-100" %>
                </div>

                <% if battle_command == "attack" %>
                  <% selected_attack_attribute = AttackAttribute.normalize(params[:attack_attribute].presence || equipped_weapon&.primary_attack_attribute || "斬撃") %>
                  <h5>攻撃種別</h5>
                  <div class="d-grid gap-2 mb-3">
                    <% AttackAttribute.normal_attack_options.each do |label, attribute| %>
                      <%= link_to label,
                          game_path(battle_command: "attack", target_enemy_id: selected_enemy&.id, attack_attribute: attribute),
                          class: selected_attack_attribute == attribute ? "btn btn-warning w-100" : "btn btn-outline-warning w-100" %>
                    <% end %>
                  </div>
                  <% if battle_enemies.many? %>
                    <h5>攻撃対象</h5>
                    <div class="d-grid gap-2">
                      <% battle_enemies.each do |enemy| %>
                        <%= link_to "#{enemy.position}. #{enemy.mob.name} Lv#{enemy.effective_level} HP #{enemy.enemy_hp}/#{enemy.effective_max_hp}",
                            game_path(battle_command: "attack", target_enemy_id: enemy.id, attack_attribute: selected_attack_attribute),
                            class: enemy == selected_enemy ? "btn btn-warning w-100" : "btn btn-outline-warning w-100" %>
                      <% end %>
                    </div>
                  <% end %>
                  <% if selected_enemy %>
                    <h5 class="<%= battle_enemies.many? ? 'mt-3' : '' %>"><%= selected_enemy.mob.name %>の攻撃部位</h5>
                    <div class="d-grid gap-2">
                      <% selected_parts.each do |part| %>
                        <% state = selected_part_states[part.id.to_s] || {} %>
                        <% part_label = state["broken"] ? "#{part.name}（破壊済み）" : part.name %>
                        <%= button_to part_label,
                            attack_path(target_enemy_id: selected_enemy.id, mob_part_id: part.id, attack_attribute: selected_attack_attribute),
                            method: :post,
                            class: "btn btn-outline-warning w-100" %>
                      <% end %>
                    </div>
                  <% end %>
                <% elsif battle_command == "sword_skill" %>
                  <% unless equipped_weapon %>
                    <p class="mb-0">武器を装備していないため、ソードスキルは使用できません。</p>
                  <% else %>
                  <% sword_skill = @player.skills.find_by(name: "片手剣") %>
                  <% sword_skill_level = (sword_skill&.proficiency || 0).to_i %>
                  <% sword_skill_definitions = SkillCatalog.sword_skills.select { |skill_definition| skill_definition.unlocked?(sword_skill_level) } %>
                  <% selected_skill = params[:selected_skill].presence %>
                  <% selected_skill = nil unless sword_skill_definitions.any? { |skill_definition| skill_definition.key == selected_skill } %>
                  <% selected_skill_definition = SkillCatalog.find(selected_skill || sword_skill_definitions.first&.key || "vertical") %>
                  <% selected_skill_definition = sword_skill_definitions.first unless sword_skill_definitions.include?(selected_skill_definition) %>
                  <% selected_skill ||= selected_skill_definition&.key %>
                  <% selected_skill_is_area = selected_skill_definition&.area? %>
                  <h5>ソードスキル</h5>
                  <div class="d-grid gap-2 mb-3">
                    <% sword_skill_definitions.each do |skill_definition| %>
                      <%= link_to skill_definition.name,
                          game_path(battle_command: "sword_skill", selected_skill: skill_definition.key),
                          class: skill_definition.key == selected_skill ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
                    <% end %>
                  </div>

                  <% if selected_skill.present? && selected_skill_is_area %>
                    <% group_start = params[:group_start].to_i %>
                    <% group_start = battle_enemies.first&.position.to_i if group_start <= 0 %>
                    <% selected_group = battle_enemies.select { |enemy| enemy.position >= group_start && enemy.position < group_start + 4 }.first(4) %>
                    <% if battle_enemies.many? %>
                      <h6>攻撃グループ</h6>
                      <div class="d-grid gap-2 mb-3">
                        <% battle_enemies.each_with_index do |enemy, index| %>
                          <% group = battle_enemies[index, 4] || [] %>
                          <% next if group.empty? %>
                          <% names = group.map { |group_enemy| "#{group_enemy.position}.#{group_enemy.mob.name}" }.join(" / ") %>
                          <%= link_to names,
                              game_path(battle_command: "sword_skill", selected_skill: selected_skill, group_start: enemy.position),
                              class: enemy.position == group_start ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
                        <% end %>
                      </div>
                    <% end %>

                    <% if selected_group.one? %>
                      <% area_enemy = selected_group.first %>
                      <% area_parts = BattleService.ensure_mob_parts!(area_enemy.mob) %>
                      <% area_part_states = (@part_states_by_enemy || {})[area_enemy.id] || {} %>
                      <h6><%= area_enemy.mob.name %>の攻撃部位</h6>
                      <div class="d-grid gap-2">
                        <% area_parts.each do |part| %>
                          <% state = area_part_states[part.id.to_s] || {} %>
                          <% part_label = state["broken"] ? "#{part.name}（破壊済み）" : part.name %>
                          <%= button_to part_label,
                              sword_skill_path(skill: selected_skill, group_start: group_start, target_enemy_id: area_enemy.id, mob_part_id: part.id),
                              method: :post,
                              class: "btn btn-outline-danger w-100" %>
                        <% end %>
                      </div>
                    <% elsif selected_group.any? %>
                      <%= button_to "#{selected_group.size}体へ発動",
                          sword_skill_path(skill: selected_skill, group_start: group_start),
                          method: :post,
                          class: "btn btn-danger w-100" %>
                      <p class="text-secondary small mt-2 mb-0">複数対象時は部位を選べず、命中しやすい部位へ自動で当たります。</p>
                    <% end %>
                  <% elsif selected_skill.present? %>
                    <% if battle_enemies.many? %>
                      <h6>攻撃対象</h6>
                      <div class="d-grid gap-2 mb-3">
                        <% battle_enemies.each do |enemy| %>
                          <%= link_to "#{enemy.position}. #{enemy.mob.name} Lv#{enemy.effective_level} HP #{enemy.enemy_hp}/#{enemy.effective_max_hp}",
                              game_path(battle_command: "sword_skill", selected_skill: selected_skill, target_enemy_id: enemy.id),
                              class: enemy == selected_enemy ? "btn btn-danger w-100" : "btn btn-outline-danger w-100" %>
                        <% end %>
                      </div>
                    <% end %>
                    <% if selected_enemy %>
                      <h6><%= selected_enemy.mob.name %>の攻撃部位</h6>
                      <div class="d-grid gap-2">
                        <% selected_parts.each do |part| %>
                          <% state = selected_part_states[part.id.to_s] || {} %>
                          <% part_label = state["broken"] ? "#{part.name}（破壊済み）" : part.name %>
                          <%= button_to part_label,
                              sword_skill_path(target_enemy_id: selected_enemy.id, mob_part_id: part.id, skill: selected_skill),
                              method: :post,
                              class: "btn btn-outline-danger w-100" %>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                  <% if selected_parts.empty? %>
                    <div class="btn btn-outline-secondary disabled w-100">攻撃可能部位なし</div>
                  <% end %>
                  <% end %>
                <% elsif battle_command == "weapon" %>
                  <% available_weapons = @player.weapons.where(equipped: false).to_a %>
                  <h5>武器を装備</h5>
                  <% if available_weapons.any? %>
                    <p>武器を装備しますか？ 装備変更には1ターン消費します。</p>
                    <div class="d-grid gap-2">
                      <% available_weapons.each do |weapon| %>
                        <div class="border rounded p-2">
                          <p class="mb-1"><%= weapon.name %></p>
                          <p class="mb-1">攻撃力: <%= weapon.attack_power %> / 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                          <% if weapon.effective_part_break_power > 100 %>
                            <p class="mb-1">特性: 部位破壊率が高い</p>
                          <% end %>
                          <p class="mb-2">補正: HP +<%= weapon.hp_bonus %> / 筋力 +<%= weapon.strength_bonus %> / 敏捷 +<%= weapon.agility_bonus %></p>
                          <%= button_to "装備する", equip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-info w-100" %>
                        </div>
                      <% end %>
                      <%= link_to "変更しない", game_path(battle_command: "attack"), class: "btn btn-outline-light w-100" %>
                    </div>
                  <% else %>
                    <p class="mb-0">装備できる武器がありません。通常攻撃または逃走を選択してください。</p>
                  <% end %>
                <% elsif battle_command == "item" %>
                  <h5>アイテム</h5>
                  <div class="d-grid gap-2">
                    <% potion = @player.items.find_by(name: "ポーション", category: "healing") || @player.items.find_by(name: "ポーション") %>
                    <% if potion&.quantity.to_i.positive? %>
                      <%= button_to "ポーション × #{potion.quantity}", use_battle_item_path(item_name: "ポーション"), method: :post, class: "btn btn-outline-success w-100" %>
                    <% else %>
                      <div class="btn btn-outline-secondary disabled w-100">使用可能なアイテムなし</div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="mb-0">コマンドを選択してください。</p>
                <% end %>
              <% else %>
              <% if selected_panel == "equipment" %>
                <h5>装備</h5>
                <% if equipped_weapons.any? %>
                  <% equipped_weapons.each do |weapon| %>
                    <div class="border rounded p-2 mb-2">
                      <p class="mb-1">武器: <%= weapon.name %></p>
                      <p class="mb-1">種別: <%= weapon.weapon_type %></p>
                      <p class="mb-1">攻撃力: <%= weapon.attack_power %></p>
                      <p class="mb-1">クリティカル率: <%= weapon.critical_rate %>%</p>
                      <p class="mb-1">耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                      <% if weapon.effective_part_break_power > 100 %>
                        <p class="mb-1">特性: 部位破壊率が高い</p>
                      <% end %>
                      <p class="mb-0">補正: HP +<%= weapon.hp_bonus %> / 筋力 +<%= weapon.strength_bonus %> / 敏捷 +<%= weapon.agility_bonus %></p>
                      <%= button_to "取り外す", unequip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
                    </div>
                  <% end %>
                  <p>武器枠: <%= equipped_weapons.count %> / <%= @player.dual_wield? ? 2 : 1 %></p>
                <% else %>
                  <p class="mb-0">装備中の武器なし</p>
                <% end %>

                <h5 class="mt-3">装備中の防具</h5>
                <p>装備重量: <%= @player.equipment_weight %> / 重量ペナルティ: <%= @player.equipment_weight_penalty %></p>
                <p>防御: <%= @player.damage_cut %></p>
                <% Armor::EQUIPPABLE_SLOTS.each do |slot| %>
                  <% armor = @player.armor_for(slot) %>
                  <p class="mb-1"><%= Armor.slot_name(slot) %>: <%= armor ? armor.name : "未装備" %></p>
                <% end %>

                <h5 class="mt-3">所持武器</h5>
                <% if @player.weapons.any? %>
                  <div class="d-grid gap-2">
                    <% @player.weapons.each do |weapon| %>
                      <div class="border rounded p-2">
                        <p class="mb-1">
                          <%= weapon.name %>
                          <% if weapon.equipped? %>
                            <span class="badge text-bg-warning">装備中</span>
                          <% end %>
                        </p>
                        <p class="mb-1">攻撃力: <%= weapon.attack_power %> / 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                        <% if weapon.effective_part_break_power > 100 %>
                          <p class="mb-1">特性: 部位破壊率が高い</p>
                        <% end %>
                        <p class="mb-1">クリティカル率: <%= weapon.critical_rate %>%</p>
                        <p class="mb-2">補正: HP +<%= weapon.hp_bonus %> / 筋力 +<%= weapon.strength_bonus %> / 敏捷 +<%= weapon.agility_bonus %></p>
                        <% unless weapon.equipped? %>
                          <p class="mb-2"><%= weapon.name %>を装備しますか？</p>
                          <%= button_to "装備する", equip_weapon_path(weapon_id: weapon.id), method: :post, class: "btn btn-outline-warning w-100" %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="mb-0">所持武器なし</p>
                <% end %>

                <h5 class="mt-3">所持防具</h5>
                <% if @player.armors.any? %>
                  <div class="d-grid gap-2">
                    <% @player.armors.each do |armor| %>
                      <div class="border rounded p-2">
                        <p class="mb-1">
                          <%= armor.name %>
                          <% if armor.equipped? %>
                            <span class="badge text-bg-info">装備中</span>
                          <% end %>
                        </p>
                        <p class="mb-1">種別: <%= armor.armor_type %> / 部位: <%= armor.slot_name %></p>
                        <p class="mb-1">防御: <%= armor.defense %> / 重量: <%= armor.weight %></p>
                        <p class="mb-2">補正: HP +<%= armor.hp_bonus %>% / 筋力 +<%= armor.strength_bonus %> / 敏捷 +<%= armor.agility_bonus %></p>
                        <% if armor.equipped? %>
                          <%= button_to "取り外す", unequip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-light w-100" %>
                        <% else %>
                          <p class="mb-2"><%= armor.name %>を装備しますか？</p>
                          <%= button_to "装備する", equip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-info w-100" %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="mb-0">所持防具なし</p>
                <% end %>
              <% elsif selected_panel == "items" %>
                <% item_category = params[:item_category].presence %>
                <h5>所持品</h5>
                <div class="d-grid gap-2 mb-3">
                  <%= link_to "所持武器", game_path(panel: "items", item_category: "weapons"), class: "btn btn-outline-light w-100" %>
                  <%= link_to "所持防具", game_path(panel: "items", item_category: "armors"), class: "btn btn-outline-light w-100" %>
                  <%= link_to "回復アイテム", game_path(panel: "items", item_category: "healing"), class: "btn btn-outline-light w-100" %>
                  <%= link_to "採取アイテム", game_path(panel: "items", item_category: "gathered"), class: "btn btn-outline-light w-100" %>
                  <%= link_to "ドロップアイテム", game_path(panel: "items", item_category: "drop"), class: "btn btn-outline-light w-100" %>
                </div>

                <% if item_category == "weapons" %>
                  <h6>所持武器</h6>
                  <% if @player.weapons.any? %>
                    <ul class="mb-0">
                      <% @player.weapons.each do |weapon| %>
                        <li><%= weapon.name %> <%= weapon.equipped? ? "（装備中）" : "" %></li>
                      <% end %>
                    </ul>
                  <% else %>
                    <p class="mb-0">所持武器なし</p>
                  <% end %>
                <% elsif item_category == "armors" %>
                  <h6>所持防具</h6>
                  <% if @player.armors.any? %>
                    <ul class="mb-0">
                      <% @player.armors.each do |armor| %>
                        <li><%= armor.name %> / <%= armor.slot_name %> <%= armor.equipped? ? "（装備中）" : "" %></li>
                      <% end %>
                    </ul>
                  <% else %>
                    <p class="mb-0">所持防具なし</p>
                  <% end %>
                <% elsif item_category == "healing" %>
                  <h6>回復アイテム</h6>
                  <% healing_items = @player.items.select { |item| item.category == "healing" && item.quantity.to_i.positive? } %>
                  <% if healing_items.any? %>
                    <ul class="mb-3">
                      <% healing_items.each do |item| %>
                        <li><%= item.name %> × <%= item.quantity %></li>
                      <% end %>
                    </ul>
                    <%= button_to "ポーションを使う", use_item_path(item_name: "ポーション"), method: :post, class: "btn btn-outline-success w-100" %>
                  <% else %>
                    <p class="mb-0">回復アイテムなし</p>
                  <% end %>
                <% elsif item_category == "gathered" %>
                  <h6>採取アイテム</h6>
                  <% gathered_items = @player.items.select { |item| item.category == "gathered" && item.quantity.to_i.positive? } %>
                  <% if gathered_items.any? %>
                    <ul class="mb-0">
                      <% gathered_items.each do |item| %>
                        <li><%= item.name %> × <%= item.quantity %></li>
                      <% end %>
                    </ul>
                  <% else %>
                    <p class="mb-0">採取アイテムなし</p>
                  <% end %>
                <% elsif item_category == "drop" %>
                  <h6>ドロップアイテム</h6>
                  <% drop_items = @player.items.select { |item| item.category == "drop" && item.quantity.to_i.positive? } %>
                  <% if drop_items.any? %>
                    <ul class="mb-0">
                      <% drop_items.each do |item| %>
                        <li><%= item.name %> × <%= item.quantity %></li>
                      <% end %>
                    </ul>
                  <% else %>
                    <p class="mb-0">ドロップアイテムなし</p>
                  <% end %>
                <% else %>
                  <p class="mb-0">種類を選択してください。</p>
                <% end %>
              <% elsif selected_panel == "skills" %>
                <% selected_skill_set = params[:skill_set].presence %>
                <% selected_sword_skill = params[:sword_skill].presence %>
                <h5>スキル</h5>
                <p>スキルスロット: <%= @player.used_skill_slots %> / <%= @player.skill_slots.to_i %>（空き <%= @player.remaining_skill_slots %>）</p>
                <% @player.skills.each do |skill| %>
                  <%= link_to "#{skill.name}: #{skill.proficiency.to_i}/1000", game_path(panel: "skills", skill_set: skill.name), class: "btn btn-outline-light w-100 mb-2" %>
                  <div class="progress mb-3">
                    <div class="progress-bar" style="width: <%= skill.proficiency.to_i / 10 %>%"></div>
                  </div>
                <% end %>
                <% if selected_skill_set == "片手剣" %>
                  <% sword_skill = @player.skills.find_by(name: "片手剣") %>
