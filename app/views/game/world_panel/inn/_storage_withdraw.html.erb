              <%= button_to "表示中の種類をすべて取り出す", bulk_withdraw_items_path(item_category: item_category), method: :post, class: "btn btn-outline-info w-100 mb-3" %>
              <% storage_items = current_base.storage_items.where("quantity > 0").order(:category, :name) %>
              <% storage_items = storage_items.where(category: item_category) if item_category.present? && !%w[weapons armors].include?(item_category) %>
              <% stored_weapons = item_category.blank? || item_category == "weapons" ? current_base.stored_weapons.order(:name) : [] %>
              <% stored_armors = item_category.blank? || item_category == "armors" ? current_base.stored_armors.order(:slot, :name) : [] %>

              <% if stored_weapons.any? %>
                <h6 class="mt-2">武器</h6>
                <div class="d-grid gap-2 mb-2">
                  <% stored_weapons.each do |weapon| %>
                    <div class="border rounded p-2">
                      <p class="mb-1"><%= weapon.display_name %> / 耐久 <%= weapon.durability %> / <%= weapon.max_durability %></p>
                      <%= button_to "取り出す", withdraw_weapon_path(weapon_id: weapon.id, item_category: item_category), method: :post, class: "btn btn-outline-light btn-sm w-100" %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <% if stored_armors.any? %>
                <h6 class="mt-2">防具</h6>
                <div class="d-grid gap-2 mb-2">
                  <% stored_armors.each do |armor| %>
                    <div class="border rounded p-2">
                      <p class="mb-1"><%= armor.name %> / <%= armor.slot_name %></p>
                      <%= button_to "取り出す", withdraw_armor_path(armor_id: armor.id, item_category: item_category), method: :post, class: "btn btn-outline-light btn-sm w-100" %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <% if item_category == "drop" %>
                <% drop_groups = storage_items.group_by { |item| item.name.to_s.split("の").first } %>
                <% if drop_groups.any? %>
                  <h6 class="mt-2">ドロップアイテム</h6>
                  <div class="d-grid gap-2">
                    <% drop_groups.each do |group_name, items| %>
                      <div class="border rounded">
                        <button class="btn btn-dark w-100 text-start" type="button" data-bs-toggle="collapse" data-bs-target="#withdraw-drop-<%= group_name.hash.abs %>"><%= group_name %>関連（<%= items.size %>種類）</button>
                        <div class="collapse p-2" id="withdraw-drop-<%= group_name.hash.abs %>">
                          <% items.each do |storage_item| %>
                            <%= form_with url: withdraw_item_path(storage_item_id: storage_item.id), method: :post, class: "d-flex gap-2 mb-2" do %>
                              <span class="flex-fill"><%= storage_item.name %> × <%= storage_item.quantity %></span>
                              <%= number_field_tag :quantity, storage_item.quantity, min: 1, max: storage_item.quantity, class: "form-control form-control-sm", style: "max-width: 90px;" %>
                              <%= submit_tag "取り出す", class: "btn btn-outline-light btn-sm" %>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% elsif !%w[weapons armors].include?(item_category.to_s) %>
                <% if storage_items.any? %>
                  <h6 class="mt-2">アイテム</h6>
                  <div class="d-grid gap-2">
                    <% storage_items.each do |storage_item| %>
                      <div class="border rounded p-2">
                        <%= form_with url: withdraw_item_path(storage_item_id: storage_item.id), method: :post, class: "d-flex gap-2" do %>
                          <span class="flex-fill"><%= storage_item.name %> × <%= storage_item.quantity %></span>
                          <%= number_field_tag :quantity, storage_item.quantity, min: 1, max: storage_item.quantity, class: "form-control form-control-sm", style: "max-width: 90px;" %>
                          <%= submit_tag "取り出す", class: "btn btn-outline-light btn-sm" %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% end %>

              <% if storage_items.empty? && stored_weapons.empty? && stored_armors.empty? %>
                <p class="text-secondary small mb-0">収納中のものはありません。</p>
              <% end %>
