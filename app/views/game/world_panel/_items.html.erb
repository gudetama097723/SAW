      <div class="card-header">所持品一覧</div>
      <div class="card-body">

        <%
          cur_sort = params[:sort_by].to_s
          cur_dir  = params[:sort_dir] == "asc" ? "asc" : "desc"
          sort_link = ->(label, col, default_dir = "asc") do
            active    = cur_sort == col
            next_dir  = active && cur_dir == default_dir ? (default_dir == "asc" ? "desc" : "asc") : default_dir
            arrow     = active ? (cur_dir == "asc" ? " ▲" : " ▼") : ""
            link_to(
              "#{label}#{arrow}",
              game_path(panel: "items", item_category: params[:item_category], sort_by: col, sort_dir: next_dir),
              class: "btn btn-sm py-0 px-2 #{active ? 'btn-secondary' : 'btn-outline-secondary'}"
            )
          end
        %>

        <% if params[:item_category] == "weapons" %>

          <div class="d-flex gap-1 mb-2 flex-wrap">
            <%= sort_link.call("名前", "name", "asc") %>
            <%= sort_link.call("攻撃力", "attack_power", "desc") %>
            <%= sort_link.call("強化", "enhancement_level", "desc") %>
            <%= sort_link.call("耐久", "durability", "desc") %>
          </div>

          <%
            weapon_cols = { "name" => "name", "attack_power" => "attack_power",
                            "enhancement_level" => "enhancement_level", "durability" => "durability" }
            w_col = weapon_cols[cur_sort] || "name"
            w_dir = cur_dir == "asc" ? :asc : :desc
          %>

          <% @player.weapons.order(w_col => w_dir).each do |weapon| %>
            <div class="border rounded mb-2">
              <button class="btn btn-dark w-100 text-start"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#weapon-item-<%= weapon.id %>">

                <%= weapon.display_name %>
                <% if weapon.equipped? %>（装備中）<% end %>

              </button>

              <div class="collapse p-2"
                  id="weapon-item-<%= weapon.id %>">

                <p class="mb-1">種別: <%= weapon.weapon_type %></p>
                <p class="mb-1">レアリティ: <%= weapon.rarity %></p>
                <p class="mb-1">攻撃力: <%= weapon.attack_power %>（強化込み <%= weapon.effective_attack_power %>）</p>
                <p class="mb-1">強化: +<%= weapon.enhancement_level.to_i %> / <%= Weapon::MAX_ENHANCEMENT_LEVEL %></p>
                <p class="mb-1">耐久力: <%= weapon.durability %>/<%= weapon.max_durability %></p>
                <p class="mb-1">攻撃属性: <%= weapon.attack_attribute_list.join(" / ") %></p>
                <p class="mb-1">クリティカル率: <%= weapon.critical_rate %>%</p>
                <p class="mb-1">部位破壊力: <%= weapon.effective_part_break_power %>%</p>
                <p class="mb-1">重量: <%= weapon.weight %></p>
                <p class="mb-1">能力反映: 筋力 <%= weapon.strength_ratio %>% / 敏捷 <%= weapon.agility_ratio %>%</p>
                <p class="mb-1">補正: HP <%= signed_bonus(weapon.hp_bonus) %> / 筋力 <%= signed_bonus(weapon.strength_bonus) %> / 敏捷 <%= signed_bonus(weapon.agility_bonus) %></p>
                <p class="mb-1">売却価格: <%= weapon.sell_price %>コル</p>
                <% if weapon.description.present? %>
                  <p class="mb-2"><%= weapon.description %></p>
                <% end %>

                <% unless weapon.equipped? %>
                  <%= button_to "装備する",
                      equip_weapon_path(weapon_id: weapon.id),
                      method: :post,
                      class: "btn btn-outline-warning w-100" %>
                <% end %>
              </div>
            </div>
          <% end %>

        <% elsif params[:item_category] == "armors" %>

          <div class="d-flex gap-1 mb-2 flex-wrap">
            <%= sort_link.call("部位", "slot", "asc") %>
            <%= sort_link.call("名前", "name", "asc") %>
            <%= sort_link.call("防御力", "defense", "desc") %>
          </div>

          <%
            armor_cols = { "name" => "name", "defense" => "defense", "slot" => "slot" }
            a_col = armor_cols[cur_sort] || "slot"
            a_dir = cur_dir == "asc" ? :asc : :desc
            a_order = a_col == "slot" ? { slot: a_dir, name: :asc } : { a_col => a_dir }
          %>

          <% @player.armors.order(a_order).each do |armor| %>

            <div class="border rounded mb-2">
              <button class="btn btn-dark w-100 text-start"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#armor-item-<%= armor.id %>">

                <%= armor.name %>
                <% if armor.equipped? %>（装備中）<% end %>

              </button>

              <div class="collapse p-2"
                  id="armor-item-<%= armor.id %>">

                <p class="mb-1">部位: <%= armor.slot_name %></p>
                <p class="mb-1">種別: <%= armor.armor_type %></p>
                <p class="mb-1">レアリティ: <%= armor.rarity %></p>
                <p class="mb-1">防御力: <%= armor.defense %></p>
                <p class="mb-1">重量: <%= armor.weight %></p>
                <p class="mb-1">補正: HP <%= signed_bonus(armor.hp_bonus) %>% / 筋力 <%= signed_bonus(armor.strength_bonus) %> / 敏捷 <%= signed_bonus(armor.agility_bonus) %></p>

                <% if armor.equipped? %>
                  <%= button_to "取り外す", unequip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-light w-100 mt-2" %>
                <% else %>
                  <%= button_to "装備する", equip_armor_path(armor_id: armor.id), method: :post, class: "btn btn-outline-info w-100 mt-2" %>
                <% end %>

              </div>
            </div>

          <% end %>

        <% elsif params[:item_category] == "key_items" %>

          <% grouped_key_items = @player.key_items.order(:category, :obtained_at, :name).group_by(&:category) %>

          <% if grouped_key_items.any? %>
            <% KeyItem::CATEGORIES.each do |category, label| %>
              <% key_items = grouped_key_items[category] || [] %>
              <% next if key_items.empty? %>

              <h6 class="mt-3"><%= label %></h6>
              <% key_items.each do |key_item| %>
                <div class="border rounded mb-2">
                  <button class="btn btn-dark w-100 text-start"
                          type="button"
                          data-bs-toggle="collapse"
                          data-bs-target="#key-item-<%= key_item.id %>">
                    <%= key_item.name %>
                  </button>

                  <div class="collapse p-2"
                      id="key-item-<%= key_item.id %>">
                    <p class="mb-1">分類: <%= key_item.category_label %></p>
                    <p class="mb-1">入手日時: <%= key_item.obtained_at_label %></p>
                    <% if key_item.description.present? %>
                      <p class="mb-0"><%= key_item.description %></p>
                    <% else %>
                      <p class="mb-0 text-secondary">説明はありません。</p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          <% else %>
            <p class="mb-0">キーアイテムはまだありません。</p>
          <% end %>

        <% elsif params[:item_category].in?(%w[healing gathered drop]) %>

          <div class="d-flex gap-1 mb-2 flex-wrap">
            <%= sort_link.call("名前", "name", "asc") %>
            <%= sort_link.call("数量", "quantity", "desc") %>
            <%= sort_link.call("売値", "sell_price", "desc") %>
          </div>

          <%
            item_cols = { "name" => "name", "quantity" => "quantity" }
            i_col = item_cols[cur_sort] || "name"
            i_dir = cur_dir == "asc" ? :asc : :desc
          %>

          <% items = @player.items.where(category: params[:item_category])
                                  .where("quantity > 0")
            items = if cur_sort == "sell_price"
                      sorted_items = items.to_a.sort_by { |item| [item.sell_price, item.name.to_s] }
                      i_dir == :desc ? sorted_items.reverse : sorted_items
                    else
                      items.order(i_col => i_dir)
                    end %>

          <% items.each do |item| %>

            <div class="border rounded mb-2">

              <button class="btn btn-dark w-100 text-start"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#item-right-<%= item.id %>">

                <%= item.name %> × <%= item.quantity %>

              </button>

              <div class="collapse p-2"
                  id="item-right-<%= item.id %>">

                <p class="mb-1">分類: <%= item.category_name %></p>
                <p class="mb-1">数量: <%= item.quantity.to_i %></p>
                <p class="mb-1">単体重量: <%= item.weight %></p>
                <p class="mb-1">合計重量: <%= item.total_weight %></p>
                <p class="mb-1">売却価格: <%= item.sell_price %>コル / 個</p>
                <p class="mb-1">売却合計: <%= item.sell_price * item.quantity.to_i %>コル</p>
                <% if item.food? %>
                  <p class="mb-1">食材: おいしさ <%= item.effective_tastiness %></p>
                <% end %>
                <% if item.description.present? %>
                  <p class="mb-2"><%= item.description %></p>
                <% end %>

                <% if item.category == "healing" %>
                  <%= button_to "使う",
                      use_item_path(item_name: item.name),
                      method: :post,
                       class: "btn btn-outline-success w-100 mb-2" %>
                <% end %>

                <% if item.edible_by?(@player) %>
                  <%= button_to "食べる",
                      eat_item_path(item_id: item.id, item_category: item.category),
                      method: :post,
                      class: "btn btn-outline-success w-100 mb-2" %>
                <% end %>

                <% if item.discardable_by_player? %>
                  <%= button_to "全部捨てる",
                      discard_item_path(
                        item_id: item.id,
                        quantity: item.quantity
                      ),
                      method: :post,
                      class: "btn btn-outline-danger w-100" %>
                <% end %>

              </div>

            </div>

          <% end %>

        <% end %>

      </div>
