        <div class="col-md-4">
          <% status_panel_open = selected_panel.blank? && params[:status_collapsed] != "1" %>
          <details class="card bg-secondary text-light mb-3 ui-collapsible" <%= "open" if status_panel_open %>>
            <summary class="card-header ui-collapsible-summary">
              <span>ステータス</span>
              <span class="small ui-collapsible-mini">
                Lv<%= @player.level.to_i %> / HP <%= @player.hp %>/<%= @player.effective_max_hp %> / <%= @player.col %> col
              </span>
            </summary>
            <div class="card-body">
              <div class="d-flex gap-3 align-items-center">
                <p>名前: <%= @player.name %></p>
                <p>Lv: <%= @player.level.to_i %></p>
                <% if @player.home_base %>
                  <p class="ms-auto">本拠点: <%= @player.home_base.location.name %></p>
                <% end %>
              </div>
              <p>
                HP: <%= @player.hp %> / <%= @player.effective_max_hp %>
                <% @player.condition_labels.each do |label| %>
                  <span class="badge bg-warning text-dark ms-1"><%= label %></span>
                <% end %>
              </p>
              <div class="progress mb-2">
                <div class="progress-bar bg-success" style="width: <%= [[@player.hp.to_i * 100 / [@player.effective_max_hp, 1].max, 0].max, 100].min %>%"></div>
              </div>
              <p>経験値: <%= @player.exp.to_i %> / <%= @player.exp_to_next_level %></p>
              <div class="progress mb-2" style="height: 6px;">
                <div class="progress-bar bg-info" style="width: <%= [[@player.exp.to_i * 100 / [@player.exp_to_next_level, 1].max, 0].max, 100].min %>%"></div>
              </div>
              <% if equipped_weapons.any? %>
                <% equipped_weapons.each do |weapon| %>
                  <p class="mb-1"><%= weapon.display_name %> 耐久力: <%= weapon.durability %> / <%= weapon.max_durability %></p>
                <% end %>
              <% end %>
              <p>スキルスロット: <%= @player.used_skill_slots %> / <%= @player.skill_slots.to_i %></p>
              <p>コル: <%= @player.col %></p>
              <p>所持重量: <%= number_with_precision(@player.carry_weight, precision: 1) %> / <%= number_with_precision(@player.max_carry_weight, precision: 1) %></p>
              <% if @player.overweight? %>
                <p class="text-warning mb-0">重量オーバー：移動速度と回避率が低下しています</p>
              <% end %>
              <% if @player.sleepiness_warning_message.present? %>
                <p class="text-warning mb-0"><%= @player.sleepiness_warning_message %></p>
              <% end %>
            </div>
          </details>

          <% if @active_player_quests.any? %>
            <details class="card bg-secondary text-light mb-3 ui-collapsible" open>
              <summary class="card-header ui-collapsible-summary">
                <span>受注中クエスト</span>
                <span class="badge bg-warning text-dark ms-auto"><%= @active_player_quests.size %></span>
              </summary>
              <div class="card-body p-2">
                <% @active_player_quests.each do |pq| %>
                  <% quest = pq.npc_quest %>
                  <% completable = NpcQuestService.completion_conditions_met?(@player, quest) %>
                  <div class="d-flex align-items-center gap-1 py-1 border-bottom border-dark">
                    <div class="flex-grow-1 small">
                      <span class="<%= completable ? "text-success fw-bold" : "" %>"><%= quest.name %></span>
                      <div class="text-secondary" style="font-size:0.75rem;">
                        <%= quest.npc.name %> ／ <%= NpcQuestService.completion_conditions_summary(quest) %>
                      </div>
                    </div>
                    <% if completable %>
                      <span class="badge bg-success" style="font-size:0.65rem;">達成</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </details>
          <% end %>

          <details class="card bg-secondary text-light mb-3 ui-collapsible" open>
            <summary class="card-header ui-collapsible-summary">
              <span>情報コマンド</span>
              <% if selected_panel.present? %>
                <span class="small ui-collapsible-mini">表示中: <%= selected_panel %></span>
              <% end %>
            </summary>
            <div class="card-body d-grid gap-2">
              <% if selected_panel == "equipment" %>
                <%= link_to "閉じる", game_path(status_collapsed: "1"), class: "btn btn-outline-danger w-100" %>
              <% else %>
                <%= link_to "装備", game_path(panel: "equipment"), class: "btn btn-outline-light w-100" %>
              <% end %>

              <% if selected_panel == "items" %>
                <%= link_to "閉じる", game_path(status_collapsed: "1"), class: "btn btn-outline-danger w-100" %>
              <% else %>
                <%= link_to "所持品", game_path(panel: "items"), class: "btn btn-outline-light w-100" %>
              <% end %>
              <% if selected_panel == "skills" %>
                <%= link_to "閉じる", game_path(status_collapsed: "1"), class: "btn btn-outline-danger w-100" %>
              <% else %>
                <%= link_to "スキル", game_path(panel: "skills"), class: "btn btn-outline-light w-100" %>
              <% end %>
              <% if selected_panel == "growth" %>
                <%= link_to "閉じる", game_path(status_collapsed: "1"), class: "btn btn-outline-danger w-100" %>
              <% else %>
              <%= link_to "ステータス", game_path(panel: "growth"), class: @player.stat_points.to_i.positive? ? "btn btn-warning w-100" : "btn btn-outline-light w-100" %>
              <% end %>
            </div>
          </details>
        </div>
